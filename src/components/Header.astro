---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const isEn = Astro.url.pathname.startsWith('/profji-library/en/');
const aboutUrl    = isEn ? '/profji-library/en/about/'    : '/profji-library/about/';
const articlesUrl = isEn ? '/profji-library/en/articles/' : '/profji-library/articles/';
---

<header>
	<nav>
		<a class="logo" href="/profji-library/">
			<span class="logo-mark">Ji</span>
			<span class="logo-text">{SITE_TITLE}</span>
		</a>
		<div class="nav-right">
			<div class="nav-links">
				<HeaderLink href={articlesUrl}>Articles</HeaderLink>
				<HeaderLink href="/profji-library/novels">Novels</HeaderLink>
				<HeaderLink href={aboutUrl}>About</HeaderLink>
				<HeaderLink href={isEn ? '/profji-library/articles/' : '/profji-library/en/articles/'}>
					{isEn ? 'KO' : 'EN'}
				</HeaderLink>
				<a class="main-site-link" href="https://jipro-ai.github.io" target="_blank" rel="noopener noreferrer">
					jipro-ai
					<svg width="9" height="9" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M5 3H3a1 1 0 0 0-1 1v5a1 1 0 0 0 1 1h5a1 1 0 0 0 1-1V7"/>
						<path d="M8 1h3m0 0v3m0-3L5 7"/>
					</svg>
				</a>
			</div>
			<span class="status-indicator">
				<span class="status-dot"></span>
			</span>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: rgba(11, 11, 14, 0.92);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		border-bottom: 1px solid var(--border);
	}
	nav {
		max-width: 960px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1em 1em;
	}
	.logo {
		display: flex;
		align-items: center;
		gap: 0.7em;
		text-decoration: none;
		color: var(--text-primary);
	}
	.logo:hover { color: var(--text-primary); }
	.logo-mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 30px;
		height: 30px;
		background: var(--accent);
		border-radius: 6px;
		font-family: var(--font-serif);
		font-size: 0.7em;
		font-weight: 700;
		color: var(--bg-primary);
		letter-spacing: 0;
	}
	.logo-text {
		font-family: var(--font-serif);
		font-weight: 400;
		font-size: 0.9em;
		letter-spacing: 0.04em;
	}
	.nav-right {
		display: flex;
		align-items: center;
		gap: 1.2em;
	}
	.nav-links { display: flex; gap: 0.2em; }
	.nav-links :global(a) {
		padding: 0.35em 0.75em;
		color: var(--text-muted);
		text-decoration: none;
		font-size: 0.8em;
		font-weight: 400;
		letter-spacing: 0.02em;
		border-radius: 4px;
		transition: color 0.3s ease;
	}
	.nav-links :global(a:hover) {
		color: var(--text-primary);
	}
	.nav-links :global(a.active) {
		color: var(--accent);
	}
	.main-site-link {
		display: inline-flex;
		align-items: center;
		gap: 0.3em;
		padding: 0.35em 0.75em;
		margin-left: 0.4em;
		color: var(--text-muted);
		text-decoration: none;
		font-size: 0.8em;
		font-family: var(--font-mono);
		letter-spacing: 0.02em;
		border: 1px solid var(--border);
		border-radius: 4px;
		transition: color 0.3s ease, border-color 0.3s ease;
	}
	.main-site-link:hover {
		color: var(--accent);
		border-color: var(--accent);
	}
	.main-site-link svg {
		opacity: 0.6;
		flex-shrink: 0;
	}
	.status-indicator {
		display: flex;
		align-items: center;
	}
	.status-dot {
		width: 6px;
		height: 6px;
		background: var(--accent);
		border-radius: 50%;
		animation: breathe 3s ease-in-out infinite;
	}
	@media (max-width: 720px) {
		.logo-text { display: none; }
		.nav-links :global(a) { padding: 0.3em 0.5em; font-size: 0.78em; }
	}
</style>
