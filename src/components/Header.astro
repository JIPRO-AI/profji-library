---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a class="logo" href="/profji-library/">
			<span class="logo-mark">Ji</span>
			<span class="logo-text">{SITE_TITLE}</span>
		</a>
		<div class="nav-right">
			<div class="nav-links">
				<HeaderLink href="/profji-library/articles">Articles</HeaderLink>
				<HeaderLink href="/profji-library/novels">Novels</HeaderLink>
				<HeaderLink href="/profji-library/about">About</HeaderLink>
			</div>
			<span class="status-indicator">
				<span class="status-dot"></span>
			</span>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: rgba(11, 11, 14, 0.92);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		border-bottom: 1px solid var(--border);
	}
	nav {
		max-width: 960px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1em 1em;
	}
	.logo {
		display: flex;
		align-items: center;
		gap: 0.7em;
		text-decoration: none;
		color: var(--text-primary);
	}
	.logo:hover { color: var(--text-primary); }
	.logo-mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 30px;
		height: 30px;
		background: var(--accent);
		border-radius: 6px;
		font-family: var(--font-serif);
		font-size: 0.7em;
		font-weight: 700;
		color: var(--bg-primary);
		letter-spacing: 0;
	}
	.logo-text {
		font-family: var(--font-serif);
		font-weight: 400;
		font-size: 0.9em;
		letter-spacing: 0.04em;
	}
	.nav-right {
		display: flex;
		align-items: center;
		gap: 1.2em;
	}
	.nav-links { display: flex; gap: 0.2em; }
	.nav-links :global(a) {
		padding: 0.35em 0.75em;
		color: var(--text-muted);
		text-decoration: none;
		font-size: 0.8em;
		font-weight: 400;
		letter-spacing: 0.02em;
		border-radius: 4px;
		transition: color 0.3s ease;
	}
	.nav-links :global(a:hover) {
		color: var(--text-primary);
	}
	.nav-links :global(a.active) {
		color: var(--accent);
	}
	.status-indicator {
		display: flex;
		align-items: center;
	}
	.status-dot {
		width: 6px;
		height: 6px;
		background: var(--accent);
		border-radius: 50%;
		animation: breathe 3s ease-in-out infinite;
	}
	@media (max-width: 720px) {
		.logo-text { display: none; }
		.nav-links :global(a) { padding: 0.3em 0.5em; font-size: 0.78em; }
	}
</style>
