---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<span class="footer-left">&copy; {today.getFullYear()} Ji Research Library</span>
		<span class="footer-right">
			<a href="https://github.com/JIPRO-AI/profji-library" target="_blank" rel="noopener">GitHub</a>
		</span>
	</div>
</footer>
<style>
	footer {
		margin-top: 6em;
		padding: 2em 1em;
		border-top: 1px solid var(--border);
	}
	.footer-inner {
		max-width: 960px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.footer-left {
		font-family: var(--font-mono);
		font-size: 0.7em;
		color: var(--text-muted);
		letter-spacing: 0.02em;
	}
	.footer-right a {
		font-family: var(--font-mono);
		font-size: 0.7em;
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.3s ease;
	}
	.footer-right a:hover { color: var(--accent); }
	@media (max-width: 720px) {
		.footer-inner { flex-direction: column; gap: 0.5em; text-align: center; }
	}
</style>
