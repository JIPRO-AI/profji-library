---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div class="footer-brand">
			<span class="footer-logo">Ji</span>
			<span>Prof. Ji e-Library</span>
		</div>
		<div class="footer-meta">
			<span>&copy; {today.getFullYear()} Professor Ji. Powered by AI + Human Curation.</span>
		</div>
		<div class="footer-links">
			<a href="https://github.com/JIPRO589/profji-library" target="_blank">GitHub</a>
		</div>
	</div>
</footer>
<style>
	footer {
		margin-top: 4em;
		padding: 2em 1em;
		border-top: 1px solid var(--border);
		background: var(--bg-secondary);
	}
	.footer-inner {
		max-width: 960px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 1em;
	}
	.footer-brand {
		display: flex;
		align-items: center;
		gap: 0.5em;
		color: var(--text-secondary);
		font-size: 0.85em;
		font-weight: 600;
	}
	.footer-logo {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 24px;
		height: 24px;
		background: linear-gradient(135deg, var(--accent), #a78bfa);
		border-radius: 5px;
		font-size: 0.65em;
		font-weight: 700;
		color: white;
	}
	.footer-meta {
		color: var(--text-muted);
		font-size: 0.8em;
	}
	.footer-links a {
		color: var(--text-muted);
		font-size: 0.8em;
		transition: color 0.2s;
	}
	.footer-links a:hover { color: var(--accent); }
	@media (max-width: 720px) {
		.footer-inner { flex-direction: column; text-align: center; }
	}
</style>
