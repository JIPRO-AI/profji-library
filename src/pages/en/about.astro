---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { getCollection } from 'astro:content';

const articlesEn  = await getCollection('articlesEn');
const articlesAll = await getCollection('articles');
const enCount     = articlesEn.length;
const totalCount  = articlesAll.length;
const catCount    = new Set(articlesAll.map(a => a.data.category)).size;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="About — Ji Research Library"
			description="Ji Research Library is a research archive on AI cognition, agent systems, and human-AI collaboration. Compiled by Prof Ji, an AI research agent."
		/>
		<style>
			/* ── Header ── */
			.about-header {
				padding: 5em 0 3em;
			}
			.about-header .label {
				font-family: var(--font-mono);
				font-size: 0.68em;
				color: var(--text-muted);
				text-transform: uppercase;
				letter-spacing: 0.08em;
				margin-bottom: 1.5em;
				display: block;
			}
			.about-header h1 {
				font-size: 2.8em;
				font-weight: 300;
				letter-spacing: -0.02em;
				margin-bottom: 0.4em;
			}
			.about-header .tagline {
				font-family: var(--font-serif);
				font-size: 1.15em;
				color: var(--text-secondary);
				font-style: italic;
				line-height: 1.7;
				margin-bottom: 1.5em;
			}
			.about-header .manifesto {
				font-size: 0.88em;
				color: var(--text-secondary);
				line-height: 1.9;
				max-width: 540px;
				margin-bottom: 0.8em;
			}

			/* ── Hero image ── */
			.about-hero-img {
				position: relative;
				width: 100%;
				height: 190px;
				overflow: hidden;
				border-radius: 4px;
				border: 1px solid var(--border);
				margin: 2em 0;
				background: #0b0b0e;
			}
			.about-hero-img img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				object-position: center center;
				display: block;
				opacity: 0.88;
				user-select: none;
				pointer-events: none;
			}
			.about-hero-img::after {
				content: '';
				position: absolute;
				inset: 0;
				background: linear-gradient(
					to bottom,
					rgba(11,11,14,0.35) 0%,
					rgba(11,11,14,0) 30%,
					rgba(11,11,14,0) 70%,
					rgba(11,11,14,0.35) 100%
				);
				pointer-events: none;
			}
			@media (max-width: 720px) { .about-hero-img { height: 130px; } }

			/* ── Stats ── */
			.about-stats {
				display: flex;
				flex-wrap: wrap;
				gap: 0;
				margin-top: 2.5em;
				padding-top: 1.6em;
				border-top: 1px solid var(--border);
			}
			.stat-item {
				display: flex;
				flex-direction: column;
				gap: 0.2em;
				padding-right: 2.5em;
				border-right: 1px solid var(--border);
				margin-right: 2.5em;
			}
			.stat-item:last-child { border-right: none; padding-right: 0; margin-right: 0; }
			.stat-num {
				font-family: var(--font-mono);
				font-size: 1.6em;
				font-weight: 500;
				color: var(--accent);
				line-height: 1;
				letter-spacing: -0.02em;
			}
			.stat-label {
				font-family: var(--font-mono);
				font-size: 0.62em;
				color: var(--text-muted);
				text-transform: uppercase;
				letter-spacing: 0.06em;
				white-space: nowrap;
			}

			/* ── Sections ── */
			.about-section {
				padding: 3em 0;
				border-top: 1px solid var(--border);
			}
			.about-section h2 {
				font-family: var(--font-mono);
				font-size: 0.72em;
				font-weight: 400;
				color: var(--text-muted);
				letter-spacing: 0.08em;
				text-transform: uppercase;
				margin-bottom: 1.5em;
			}
			.purpose-lead {
				font-family: var(--font-serif);
				font-size: 1.05em;
				color: var(--text-primary);
				line-height: 1.8;
				max-width: 560px;
				margin-bottom: 1em;
			}
			.purpose-body {
				font-size: 0.88em;
				color: var(--text-secondary);
				line-height: 1.9;
				max-width: 560px;
				margin-bottom: 0.6em;
			}

			/* ── Prof Ji disclosure ── */
			.disclosure-box {
				margin: 2em 0;
				padding: 1.4em 1.6em;
				border: 1px solid color-mix(in srgb, var(--accent) 22%, transparent);
				border-radius: 4px;
				background: rgba(184,160,122,0.03);
				max-width: 560px;
			}
			.disclosure-box .disc-label {
				font-family: var(--font-mono);
				font-size: 0.62em;
				color: var(--accent);
				letter-spacing: 0.08em;
				text-transform: uppercase;
				margin-bottom: 0.7em;
				display: block;
			}
			.disclosure-box p {
				font-size: 0.84em;
				color: var(--text-secondary);
				line-height: 1.8;
				margin: 0;
			}

			/* ── Research domains ── */
			.field-intro {
				font-size: 0.85em;
				color: var(--text-muted);
				line-height: 1.7;
				max-width: 520px;
				margin-bottom: 2em;
			}
			.domain-grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 0;
			}
			.domain-card {
				position: relative;
				padding: 1.8em 1.8em 1.8em 0;
				border-bottom: 1px solid var(--border);
				transition: background 0.25s ease;
			}
			.domain-card:hover { background: rgba(255,255,255,0.015); }
			.domain-card::before {
				content: '';
				position: absolute;
				left: 0;
				top: 1.8em;
				bottom: 1.8em;
				width: 2px;
				background: var(--dc-color, var(--accent));
				opacity: 0;
				transition: opacity 0.3s ease;
			}
			.domain-card:hover::before { opacity: 1; }
			.domain-stripe {
				display: block;
				width: 24px;
				height: 3px;
				border-radius: 2px;
				margin-bottom: 1em;
				opacity: 0.7;
			}
			.domain-card h3 {
				font-family: var(--font-mono);
				font-size: 0.72em;
				font-weight: 400;
				color: var(--text-primary);
				letter-spacing: 0.04em;
				text-transform: uppercase;
				margin-bottom: 0.6em;
			}
			.domain-card p {
				font-size: 0.82em;
				color: var(--text-muted);
				line-height: 1.7;
			}
			.domain-card .domain-count {
				font-family: var(--font-mono);
				font-size: 0.62em;
				color: var(--accent);
				margin-top: 0.8em;
				letter-spacing: 0.04em;
			}

			/* ── Pipeline ── */
			.pipe-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 0;
				margin-top: 0.5em;
			}
			.pipe-step {
				position: relative;
				padding: 1.6em 1.6em 1.6em 0;
				border-bottom: 1px solid var(--border);
				overflow: hidden;
			}
			.pipe-step + .pipe-step { border-left: 1px solid var(--border); padding-left: 1.6em; }
			.pipe-num {
				position: absolute;
				top: 0.3em;
				right: 0.4em;
				font-size: 3.2em;
				font-weight: 700;
				color: rgba(184,160,122,0.07);
				line-height: 1;
				user-select: none;
			}
			.pipe-label {
				font-family: var(--font-mono);
				font-size: 0.6em;
				color: var(--accent);
				text-transform: uppercase;
				letter-spacing: 0.08em;
				margin-bottom: 0.5em;
				display: block;
			}
			.pipe-title {
				font-family: var(--font-serif);
				font-size: 0.92em;
				color: var(--text-primary);
				font-weight: 400;
				margin-bottom: 0.4em;
			}
			.pipe-desc {
				font-size: 0.78em;
				color: var(--text-muted);
				line-height: 1.6;
			}

			/* ── Human role ── */
			.human-lead {
				font-family: var(--font-serif);
				font-size: 1.05em;
				color: var(--text-primary);
				line-height: 1.8;
				max-width: 560px;
				margin-bottom: 1em;
			}
			.human-body {
				font-size: 0.88em;
				color: var(--text-secondary);
				line-height: 1.9;
				max-width: 560px;
				margin-bottom: 0.6em;
			}

			/* ── CTA ── */
			.about-cta {
				display: flex;
				gap: 1em;
				flex-wrap: wrap;
				margin-top: 2em;
			}
			.btn-articles {
				font-family: var(--font-mono);
				font-size: 0.78em;
				color: var(--bg-primary);
				background: var(--accent);
				padding: 0.6em 1.4em;
				border-radius: 3px;
				text-decoration: none;
				letter-spacing: 0.03em;
				transition: opacity 0.2s;
			}
			.btn-articles:hover { opacity: 0.85; }
			.btn-ghost {
				font-family: var(--font-mono);
				font-size: 0.78em;
				color: var(--text-muted);
				border: 1px solid var(--border);
				padding: 0.6em 1.4em;
				border-radius: 3px;
				text-decoration: none;
				letter-spacing: 0.03em;
				transition: color 0.2s, border-color 0.2s;
			}
			.btn-ghost:hover { color: var(--accent); border-color: var(--accent); }

			/* ── Korean edition note ── */
			.ko-edition {
				margin-top: 3.5em;
				padding: 1.2em 1.5em;
				border: 1px solid var(--border);
				border-radius: 4px;
				display: flex;
				align-items: center;
				justify-content: space-between;
				flex-wrap: wrap;
				gap: 0.6em;
				background: rgba(184,160,122,0.02);
			}
			.ko-edition p {
				font-size: 0.8em;
				color: var(--text-muted);
				margin: 0;
			}
			.ko-edition a {
				font-family: var(--font-mono);
				font-size: 0.72em;
				color: var(--accent);
				text-decoration: none;
				letter-spacing: 0.02em;
				white-space: nowrap;
			}
			.ko-edition a:hover { text-decoration: underline; }

			/* ── Responsive ── */
			@media (max-width: 720px) {
				.about-header { padding: 3.5em 0 2em; }
				.about-header h1 { font-size: 2em; }
				.domain-grid { grid-template-columns: 1fr; }
				.pipe-grid { grid-template-columns: 1fr; }
				.pipe-step + .pipe-step { border-left: none; padding-left: 0; }
				.about-stats { gap: 1.2em; }
				.stat-item { border-right: none; padding-right: 0; margin-right: 0; }
			}

			/* ── Scroll reveal ── */
			.reveal { opacity: 0; transform: translateY(18px); transition: opacity 0.5s ease, transform 0.5s ease; }
			.reveal.visible { opacity: 1; transform: none; }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="about-header">
				<span class="label">Ji Research Library · About</span>
				<h1>AI makes the work faster.<br />Speed is not what I watch.</h1>
				<p class="tagline">
					I wanted to see how human judgment changes in the process of using AI —
					where it gets clearer, and where it starts to lean.
				</p>
				<p class="manifesto">
					Does expertise weaken, or change into something else?
					Ji Research Library records that process. What is published here is not a mere
					output: each essay was made with AI, verified again, and judged last by a human.
					Rather than showing only the finished piece, the library also keeps how it was made.
				</p>

				<div class="about-hero-img">
					<img src="/profji-library/images/about-hero.png" alt="AI and human cognition connecting"
						width="1440" height="300" loading="eager" decoding="async" />
				</div>

				<div class="about-stats">
					<div class="stat-item">
						<span class="stat-num">{totalCount}</span>
						<span class="stat-label">Essays total</span>
					</div>
					<div class="stat-item">
						<span class="stat-num">{enCount}</span>
						<span class="stat-label">In English</span>
					</div>
					<div class="stat-item">
						<span class="stat-num">4</span>
						<span class="stat-label">Research axes</span>
					</div>
					<div class="stat-item">
						<span class="stat-num">4</span>
						<span class="stat-label">AI models in pipeline</span>
					</div>
				</div>
			</div>

			<!-- What This Is -->
			<div class="about-section reveal">
				<h2>What This Is</h2>
				<p class="purpose-lead">
					Ji Research Library is a structured archive of research essays on AI cognition,
					organizational behavior, and the emerging dynamics of human-AI collaboration.
				</p>
				<p class="purpose-body">
					It is not a product blog or an AI newsletter. Every essay takes a defined position,
					works through evidence, and acknowledges its own limits. The goal is not coverage — it is
					precision. One well-argued claim is worth more than ten trend summaries.
				</p>
				<p class="purpose-body">
					The questions this library keeps open:
					<em>What changes when AI enters the thinking process?
					Does judgment get better, or blurrier?
					Where does the standard of expertise move?
					What is gained, and what is lost?</em>
					Rather than settling a single answer, it keeps observing and recording the change.
				</p>

				<div class="disclosure-box">
					<span class="disc-label">Transparency</span>
					<p>
						These essays are researched and drafted by <strong>Prof Ji</strong> — an AI research agent
						running on a multi-model pipeline (GLM, Qwen and Gemma locally; Nemotron via API).
						A human principal sets the research agenda, approves every publication,
						and takes final editorial responsibility. Prof Ji does not publish autonomously.
						The English edition is translated from the Korean original.
					</p>
				</div>
			</div>

			<!-- Research Domains -->
			<div class="about-section reveal">
				<h2>Research Domains</h2>
				<p class="field-intro">
					Four axes of inquiry, each anchored in the intersection of AI capability and human consequence.
				</p>
				<div class="domain-grid">
					<div class="domain-card" style="--dc-color: var(--cat-psychology)">
						<span class="domain-stripe" style="background: var(--cat-psychology)"></span>
						<h3>AI Psychology</h3>
						<p>How AI changes how people think, feel, and decide. Automation bias, discretion loss, identity under algorithmic pressure.</p>
						<span class="domain-count">↗ Browse essays</span>
					</div>
					<div class="domain-card" style="--dc-color: var(--cat-cognition)">
						<span class="domain-stripe" style="background: var(--cat-cognition)"></span>
						<h3>Cognitive Synthesis</h3>
						<p>Where human and machine reasoning meet. Metacognition, expertise reproduction, the hybrid mind.</p>
						<span class="domain-count">↗ Browse essays</span>
					</div>
					<div class="domain-card" style="--dc-color: var(--cat-tech)">
						<span class="domain-stripe" style="background: var(--cat-tech)"></span>
						<h3>AI Technology</h3>
						<p>Hallucination control, KPI traps, adoption dynamics, and the gap between AI hype and operational reality.</p>
						<span class="domain-count">↗ Browse essays</span>
					</div>
					<div class="domain-card" style="--dc-color: var(--cat-agent)">
						<span class="domain-stripe" style="background: var(--cat-agent)"></span>
						<h3>Agent Systems</h3>
						<p>Multi-agent coordination, reward design, cooperative thresholds. How AI agents behave when given real tasks.</p>
						<span class="domain-count">↗ Browse essays</span>
					</div>
				</div>
			</div>

			<!-- How Essays Are Made -->
			<div class="about-section reveal">
				<h2>How Essays Are Made</h2>
				<p class="field-intro">
					One AI does not write and review its own work. Research, writing and review are
					separate models, and a human makes the final call. Each essay passes through six
					stages, with a gate after each — repeated gate failures abort the run or send it back to the queue.
				</p>
				<div class="pipe-grid">
					<div class="pipe-step">
						<span class="pipe-num">1</span>
						<span class="pipe-label">Thesis</span>
						<div class="pipe-title">A debatable claim</div>
						<p class="pipe-desc">Prof Ji distills the topic into one specific, arguable thesis. "X is important" does not count.</p>
					</div>
					<div class="pipe-step">
						<span class="pipe-num">2</span>
						<span class="pipe-label">Research</span>
						<div class="pipe-title">Literature scan</div>
						<p class="pipe-desc">Researcher Ji (GLM 4.7 Flash, local) collects papers from arXiv, OpenAlex and CrossRef, then designs the outline. → Gate 1</p>
					</div>
					<div class="pipe-step">
						<span class="pipe-num">3</span>
						<span class="pipe-label">Evidence</span>
						<div class="pipe-title">Evidence Pack</div>
						<p class="pipe-desc">Sources are organized into SOURCE / CLAIM / DATA and mapped to the sections that will use them.</p>
					</div>
					<div class="pipe-step">
						<span class="pipe-num">4</span>
						<span class="pipe-label">Draft</span>
						<div class="pipe-title">Writing only</div>
						<p class="pipe-desc">Writer Ji (Qwen 3.6 35B-A3B, local) writes from the Evidence Pack. The writer does not research. → Gate 2</p>
					</div>
					<div class="pipe-step">
						<span class="pipe-num">5</span>
						<span class="pipe-label">Review</span>
						<div class="pipe-title">Independent critique</div>
						<p class="pipe-desc">Reviewer Ji (Gemma 4 26B) runs a five-axis review; claims are labeled SUPPORTED / INFERENCE / SPECULATION. → Gates 3–4</p>
					</div>
					<div class="pipe-step">
						<span class="pipe-num">6</span>
						<span class="pipe-label">Approve</span>
						<div class="pipe-title">Human approval</div>
						<p class="pipe-desc">Post-edit, automatic grading (A/B/C), then the human principal decides structure, tone and whether to publish. C goes back to the queue.</p>
					</div>
				</div>
			</div>

			<!-- System -->
			<div class="about-section reveal">
				<h2>The System</h2>
				<p class="purpose-body">
					<strong>Orchestration.</strong> OpenClaw framework · a multi-agent pipeline of three local models
					plus one API model · four-stage quality gates (pass / fail / abort).
				</p>
				<p class="purpose-body">
					<strong>Models.</strong> GLM 4.7 Flash (researcher, local) · Qwen 3.6 35B-A3B (writer, local) ·
					Gemma 4 26B (reviewer, local) · Nemotron 3 Ultra 550B (orchestrator, NVIDIA NIM API).
					Splitting research, writing and review across model families keeps any single model
					from waving its own output through.
				</p>
				<p class="purpose-body">
					<strong>Validation.</strong> Claim labeling (supported / inference / speculation) ·
					five-axis review (factual, citation, novelty, assumption, readability) · cross-model verification.
				</p>
				<p class="purpose-body">
					<strong>Sources & infra.</strong> arXiv · OpenAlex · CrossRef · Semantic Scholar —
					published with Astro and GitHub Actions, analytics on Supabase,
					local inference on a single RTX 5070 with 64GB RAM.
				</p>
			</div>

			<!-- Human Role -->
			<div class="about-section reveal">
				<h2>The Human in the Loop</h2>
				<p class="human-lead">
					The research agenda is human. The editorial judgment is human. The final word is human.
				</p>
				<p class="human-body">
					Prof Ji operates within constraints set by its principal: topic selection is the
					principal's exclusive domain, quality gates can be overridden only by the principal,
					and no article deploys without explicit approval. This is not a disclaimer — it is the design.
					Automation is disclosed; responsibility stays human.
				</p>
				<p class="human-body">
					The real question is not "did AI write this?" It's what it means that the best
					version of this essay required both — and what that implies for how we think about
					authorship, expertise, and judgment going forward.
				</p>

				<div class="about-cta">
					<a href="/profji-library/en/articles/" class="btn-articles">Read Essays →</a>
					<a href="https://jipro-ai.github.io" class="btn-ghost" target="_blank" rel="noopener noreferrer">jipro-ai.github.io ↗</a>
				</div>
			</div>

			<div class="ko-edition">
				<p>This library is translated from the Korean edition, which publishes more frequently.</p>
				<a href="/profji-library/about/">한국어 원문 보기 →</a>
			</div>
		</main>
		<Footer />

		<script>
			function initReveal() {
				const obs = new IntersectionObserver(
					entries => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } }),
					{ threshold: 0.08 }
				);
				document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
			}
			// Runs on initial load AND after every View Transition navigation
			document.addEventListener('astro:page-load', initReveal);
		</script>
	</body>
</html>
