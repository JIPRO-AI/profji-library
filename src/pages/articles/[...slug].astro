---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import ArticlePost from '../../layouts/ArticlePost.astro';

export async function getStaticPaths() {
	const articles    = await getCollection('articles');
	const articlesEn  = await getCollection('articlesEn');
	const enSlugs     = new Set(articlesEn.map(a => a.data.originalSlug));

	return articles.map((article) => ({
		params: { slug: article.id },
		props: {
			article,
			hasEnglish: enSlugs.has(article.id),
		},
	}));
}

interface Props {
	article: CollectionEntry<'articles'>;
	hasEnglish: boolean;
}

const { article, hasEnglish } = Astro.props;
const { Content } = await render(article);

const base      = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const ogImage   = new URL(`${base}og-v3/${article.id}.png`,            Astro.site).href;
const heroImage = new URL(`${base}images/articles/${article.id}.png`, Astro.site).href;
const enUrl     = hasEnglish ? `/profji-library/en/articles/${article.id}/` : undefined;
---

<ArticlePost
	{...article.data}
	slug={article.id}
	ogImage={ogImage}
	heroImage={heroImage}
	lang="ko"
	enUrl={enUrl}
>
	<Content />
	<div class="colophon">
		<span class="colophon-label">이 글이 만들어진 방식</span>
		조사·작성·검증을 서로 다른 모델이 나눠 맡고, 게이트를 거쳐, 사람이 마지막으로 판단했다.
		<a href="/profji-library/about/">과정 전체 보기 →</a>
	</div>
</ArticlePost>

<style>
	.colophon {
		margin-top: 3.5em;
		padding-top: 1.4em;
		border-top: 1px solid var(--border);
		font-size: 0.78em;
		color: var(--text-muted);
		line-height: 1.8;
		word-break: keep-all;
	}
	.colophon-label {
		display: block;
		font-family: var(--font-mono);
		font-size: 0.82em;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--accent);
		opacity: 0.85;
		margin-bottom: 0.4em;
	}
	.colophon a {
		color: var(--text-muted);
		text-decoration: underline;
		text-underline-offset: 3px;
	}
	.colophon a:hover {
		color: var(--accent);
	}
</style>
