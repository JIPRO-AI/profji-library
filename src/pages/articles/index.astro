---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const articles = (await getCollection('articles')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const categories = [...new Set(articles.map(a => a.data.category))];
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`Articles | ${SITE_TITLE}`} description="AI 연구 아티클 모음" />
		<style>
			main { width: 960px; max-width: calc(100% - 2em); margin: auto; padding: 2em 0; }
			h1 { font-size: 2em; margin-bottom: 0.5em; }
			.category-filter { display: flex; gap: 0.5em; flex-wrap: wrap; margin-bottom: 2em; }
			.cat-btn { padding: 0.4em 1em; border: 1px solid rgba(var(--gray-light), 0.5); border-radius: 20px; font-size: 0.85em; cursor: pointer; background: white; }
			.cat-btn:hover { background: rgba(var(--accent), 0.1); }
			.article-list { list-style: none; padding: 0; }
			.article-list li { padding: 1em 0; border-bottom: 1px solid rgba(var(--gray-light), 0.3); }
			.article-list a { text-decoration: none; color: rgb(var(--black)); }
			.article-list a:hover h3 { color: rgb(var(--accent)); }
			.article-list h3 { margin: 0 0 0.3em; font-size: 1.1em; }
			.meta { color: rgb(var(--gray)); font-size: 0.85em; }
			.desc { color: rgb(var(--gray)); font-size: 0.9em; margin-top: 0.3em; }
			.category-tag { display: inline-block; padding: 0.15em 0.5em; background: rgba(var(--accent), 0.1); border-radius: 4px; font-size: 0.8em; margin-right: 0.5em; }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Articles</h1>
			<p style="color: rgb(var(--gray));">AI 시대의 인간 지능을 탐구하는 연구 아티클 ({articles.length}편)</p>
			<ul class="article-list">
				{articles.map((article) => (
					<li>
						<a href={`/profji-library/articles/${article.id}/`}>
							<h3><span class="category-tag">{article.data.category}</span>{article.data.title}</h3>
							<div class="meta"><FormattedDate date={article.data.pubDate} /></div>
							<div class="desc">{article.data.description}</div>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>
