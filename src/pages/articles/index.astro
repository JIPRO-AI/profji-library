---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const articles = (await getCollection('articles')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const catColors: Record<string, string> = {
	'AI 심리학': 'var(--cat-psychology)',
	'인지 융합': 'var(--cat-cognition)',
	'AI 기술': 'var(--cat-tech)',
	'에이전트': 'var(--cat-agent)',
};
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`Articles | ${SITE_TITLE}`} description="AI 연구 아티클 모음" />
		<style>
			.page-header {
				padding: 2em 0 1em;
			}
			.page-header h1 {
				font-size: 2em;
				margin-bottom: 0.3em;
			}
			.page-header p {
				color: var(--text-muted);
				font-size: 0.9em;
			}
			.article-grid {
				display: grid;
				gap: 1px;
				background: var(--border);
				border-radius: 12px;
				overflow: hidden;
			}
			.article-card {
				background: var(--bg-card);
				padding: 1.2em 1.5em;
				transition: background 0.2s;
			}
			.article-card:hover { background: var(--bg-card-hover); }
			.article-card a { text-decoration: none; color: inherit; display: block; }
			.card-top {
				display: flex;
				align-items: center;
				gap: 0.8em;
				margin-bottom: 0.5em;
			}
			.cat-dot {
				width: 8px;
				height: 8px;
				border-radius: 50%;
				flex-shrink: 0;
			}
			.cat-label {
				font-size: 0.7em;
				color: var(--text-muted);
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}
			.card-date {
				font-size: 0.7em;
				color: var(--text-muted);
				margin-left: auto;
			}
			.article-card h3 {
				margin: 0;
				font-size: 1em;
				font-weight: 600;
				color: var(--text-primary);
				line-height: 1.4;
			}
			.card-desc {
				margin-top: 0.4em;
				font-size: 0.8em;
				color: var(--text-muted);
				line-height: 1.5;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>Articles</h1>
				<p>AI 시대의 인간 지능을 탐구하는 연구 아티클 ({articles.length}편)</p>
			</div>
			<div class="article-grid">
				{articles.map((article) => {
					const color = catColors[article.data.category] || 'var(--accent)';
					return (
						<div class="article-card">
							<a href={`/profji-library/articles/${article.id}/`}>
								<div class="card-top">
									<span class="cat-dot" style={`background: ${color}`}></span>
									<span class="cat-label">{article.data.category}</span>
									<span class="card-date"><FormattedDate date={article.data.pubDate} /></span>
								</div>
								<h3>{article.data.title}</h3>
								<div class="card-desc">{article.data.description}</div>
							</a>
						</div>
					);
				})}
			</div>
		</main>
		<Footer />
	</body>
</html>
