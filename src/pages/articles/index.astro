---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import ViewCounter from '../../components/ViewCounter.astro';
import { SITE_TITLE } from '../../consts';

const articles = (await getCollection('articles')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const catColors: Record<string, string> = {
	'AI 심리학': 'var(--cat-psychology)',
	'인지 융합': 'var(--cat-cognition)',
	'AI 기술': 'var(--cat-tech)',
	'에이전트': 'var(--cat-agent)',
	'LLM 아키텍처': 'var(--cat-tech)',
};

const featured = articles[0];
const rest = articles.slice(1);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`Articles | ${SITE_TITLE}`} description="AI 연구 아티클 아카이브" />
		<style>
			.page-header {
				padding: 4em 0 1em;
			}
			.page-header h1 {
				font-size: 2.4em;
				font-weight: 300;
				margin-bottom: 0.3em;
			}
			.page-header .count {
				font-family: var(--font-mono);
				font-size: 0.82em;
				color: var(--text-muted);
				letter-spacing: 0.04em;
			}
			.page-header .count .num {
				color: var(--accent);
			}

			/* ── Featured ── */
			.featured {
				padding: 2.5em 0;
				border-top: 1px solid var(--border);
				border-bottom: 1px solid var(--border);
				margin-bottom: 0;
			}
			.featured a { text-decoration: none; color: inherit; display: block; }
			.featured .cat-row {
				display: flex;
				align-items: center;
				gap: 0.6em;
				margin-bottom: 1em;
			}
			.cat-dot {
				width: 7px;
				height: 7px;
				border-radius: 50%;
				flex-shrink: 0;
			}
			.cat-name {
				font-family: var(--font-mono);
				font-size: 0.78em;
				color: var(--text-muted);
				text-transform: uppercase;
				letter-spacing: 0.06em;
			}
			.featured h2 {
				font-size: 1.8em;
				font-weight: 400;
				line-height: 1.35;
				margin-bottom: 0.6em;
				transition: color 0.3s;
			}
			.featured a:hover h2 { color: var(--accent); }
			.featured .desc {
				font-size: 0.9em;
				color: var(--text-secondary);
				line-height: 1.75;
				max-width: 640px;
				margin-bottom: 1em;
			}
			.featured .date {
				font-family: var(--font-mono);
				font-size: 0.78em;
				color: var(--text-muted);
			}

			/* ── Article Index ── */
			.article-index {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.article-row {
				display: flex;
				align-items: baseline;
				gap: 1.2em;
				padding: 1.1em 0;
				border-bottom: 1px solid var(--border);
				transition: background 0.3s ease;
			}
			.article-row:hover {
				background: var(--accent-dim);
			}
			.article-row a {
				text-decoration: none;
				color: inherit;
				display: flex;
				align-items: baseline;
				gap: 1.2em;
				width: 100%;
			}
			.article-row .row-date {
				font-family: var(--font-mono);
				font-size: 0.78em;
				color: var(--text-muted);
				flex-shrink: 0;
				min-width: 6.5em;
			}
			.article-row .row-cat {
				display: flex;
				align-items: center;
				gap: 0.4em;
				flex-shrink: 0;
				min-width: 7em;
			}
			.article-row .row-title {
				font-family: var(--font-serif);
				font-size: 0.95em;
				font-weight: 400;
				color: var(--text-primary);
				line-height: 1.4;
			}

			@media (max-width: 720px) {
				.page-header h1 { font-size: 1.8em; }
				.featured h2 { font-size: 1.4em; }
				.article-row a { flex-wrap: wrap; gap: 0.3em; }
				.article-row .row-date { min-width: auto; }
				.article-row .row-cat { min-width: auto; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>Articles</h1>
				<span class="count"><span class="num">{articles.length}</span> research articles</span>
			</div>

			{featured && (
				<div class="featured">
					<a href={`/profji-library/articles/${featured.id}/`}>
						<div class="cat-row">
							<span class="cat-dot" style={`background: ${catColors[featured.data.category] || 'var(--accent)'}`}></span>
							<span class="cat-name">{featured.data.category}</span>
						</div>
						<h2>{featured.data.title}</h2>
						<div class="desc">{featured.data.description}</div>
						<span class="date"><FormattedDate date={featured.data.pubDate} /> <span style="margin-left: 1em;"><ViewCounter slug={featured.id} /></span></span>
					</a>
				</div>
			)}

			<ul class="article-index">
				{rest.map((article) => (
					<li class="article-row">
						<a href={`/profji-library/articles/${article.id}/`}>
							<span class="row-date"><FormattedDate date={article.data.pubDate} /></span>
							<span class="row-cat">
								<span class="cat-dot" style={`background: ${catColors[article.data.category] || 'var(--accent)'}`}></span>
								<span class="cat-name">{article.data.category}</span>
							</span>
							<span class="row-title">{article.data.title}</span>
							<span style="margin-left: auto; flex-shrink: 0;"><ViewCounter slug={article.id} /></span>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>
