---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const novels = (await getCollection('novels')).sort(
	(a, b) => a.data.episode - b.data.episode,
);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`Novels | ${SITE_TITLE}`} description="AI 시대 소설 시리즈" />
		<style>
			.page-header {
				padding: 4em 0 1em;
			}
			.page-header h1 {
				font-size: 2.4em;
				font-weight: 300;
				margin-bottom: 0.3em;
			}
			.page-header .series-name {
				font-family: var(--font-serif);
				font-size: 0.95em;
				color: var(--text-secondary);
				font-style: italic;
			}
			.chapter-list {
				border-top: 1px solid var(--border);
				margin-top: 2em;
			}
			.chapter {
				display: block;
				padding: 2em 0;
				border-bottom: 1px solid var(--border);
				text-decoration: none;
				color: inherit;
				transition: padding-left 0.3s ease;
			}
			.chapter:hover { padding-left: 0.8em; }
			.chapter-top {
				display: flex;
				align-items: baseline;
				gap: 1.2em;
				margin-bottom: 0.6em;
			}
			.chapter-ep {
				font-family: var(--font-mono);
				font-size: 0.72em;
				color: var(--accent);
				letter-spacing: 0.03em;
			}
			.chapter h2 {
				font-size: 1.3em;
				font-weight: 400;
				margin: 0;
				line-height: 1.4;
			}
			.chapter .desc {
				font-size: 0.88em;
				color: var(--text-secondary);
				line-height: 1.7;
				max-width: 560px;
				padding-left: 4.5em;
			}
			@media (max-width: 720px) {
				.page-header h1 { font-size: 1.8em; }
				.chapter .desc { padding-left: 0; }
				.chapter-top { flex-direction: column; gap: 0.3em; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>Novels</h1>
				<span class="series-name">AI시대 인간 직장인 생존법</span>
			</div>

			<div class="chapter-list">
				{novels.map((novel) => (
					<a class="chapter" href={`/profji-library/novels/${novel.id}/`}>
						<div class="chapter-top">
							<span class="chapter-ep">EP.{novel.data.episode}</span>
							<h2>{novel.data.title}</h2>
						</div>
						<div class="desc">{novel.data.description}</div>
					</a>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>
