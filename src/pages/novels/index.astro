---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const novels = (await getCollection('novels')).sort(
	(a, b) => a.data.episode - b.data.episode,
);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`Novels | ${SITE_TITLE}`} description="AI 시대 소설 시리즈" />
		<style>
			.page-header { padding: 2em 0 1em; }
			.page-header h1 { font-size: 2em; margin-bottom: 0.3em; }
			.page-header p { color: var(--text-muted); font-size: 0.9em; }
			.novel-list { display: grid; gap: 1em; padding: 0; list-style: none; }
			.novel-card {
				background: var(--bg-card);
				border: 1px solid var(--border);
				border-radius: 12px;
				padding: 1.5em 2em;
				transition: all 0.25s;
				position: relative;
				overflow: hidden;
			}
			.novel-card::before {
				content: '';
				position: absolute;
				top: 0; left: 0; right: 0;
				height: 3px;
				background: linear-gradient(90deg, var(--accent), #a78bfa);
			}
			.novel-card:hover {
				border-color: var(--border-light);
				transform: translateY(-2px);
				box-shadow: var(--box-shadow);
			}
			.novel-card a { text-decoration: none; color: inherit; display: block; }
			.ep-badge {
				display: inline-block;
				padding: 0.2em 0.6em;
				background: var(--accent-dim);
				color: var(--accent);
				border-radius: 4px;
				font-size: 0.75em;
				font-weight: 700;
				margin-bottom: 0.6em;
			}
			.novel-card h3 { font-size: 1.15em; margin-bottom: 0.5em; line-height: 1.4; }
			.novel-card .desc { font-size: 0.85em; color: var(--text-muted); line-height: 1.6; }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>Novels</h1>
				<p>AI 시대를 배경으로 한 소설 시리즈</p>
			</div>
			<ul class="novel-list">
				{novels.map((novel) => (
					<li class="novel-card">
						<a href={`/profji-library/novels/${novel.id}/`}>
							<span class="ep-badge">EP.{novel.data.episode}</span>
							<h3>{novel.data.title}</h3>
							<div class="desc">{novel.data.description}</div>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>
