---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import ViewCounter from '../components/ViewCounter.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const articles = (await getCollection('articles')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const novels = (await getCollection('novels')).sort(
	(a, b) => a.data.episode - b.data.episode,
);

const catColors: Record<string, string> = {
	'AI 심리학': 'var(--cat-psychology)',
	'인지 융합': 'var(--cat-cognition)',
	'AI 기술': 'var(--cat-tech)',
	'에이전트': 'var(--cat-agent)',
	'LLM 아키텍처': 'var(--cat-tech)',
};

const featured = articles[0];
const rest = articles.slice(1);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* ── Hero ── */
			.hero {
				padding: 5em 0 3em;
			}
			.hero-status {
				display: inline-flex;
				align-items: center;
				gap: 0.5em;
				font-family: var(--font-mono);
				font-size: 0.8em;
				color: var(--text-muted);
				letter-spacing: 0.05em;
				text-transform: uppercase;
				margin-bottom: 2em;
				position: relative;
				height: 1.4em;
			}
			.hero-status .dot {
				width: 5px;
				height: 5px;
				background: var(--accent);
				border-radius: 50%;
				animation: breathe 3s ease-in-out infinite;
				flex-shrink: 0;
			}
			.status-text {
				position: relative;
				display: inline-block;
			}
			.status-text span {
				position: absolute;
				left: 0;
				top: 0;
				white-space: nowrap;
				opacity: 0;
				animation: statusCycle 8s ease-in-out infinite;
			}
			.status-text span:nth-child(1) { animation-delay: 0s; }
			.status-text span:nth-child(2) { animation-delay: 2s; }
			.status-text span:nth-child(3) { animation-delay: 4s; }
			.status-text span:nth-child(4) { animation-delay: 6s; }
			.status-text .status-sizer {
				position: relative;
				visibility: hidden;
			}
			.hero h1 {
				font-size: 2.8em;
				font-weight: 300;
				letter-spacing: -0.03em;
				line-height: 1.15;
				margin-bottom: 0.4em;
			}
			.hero .subtitle {
				color: var(--text-secondary);
				font-size: 1.05em;
				line-height: 1.75;
				max-width: 540px;
			}
			.hero .meta-bar {
				margin-top: 2.5em;
				padding-top: 1.5em;
				border-top: 1px solid var(--border);
				display: flex;
				gap: 2.5em;
				font-family: var(--font-mono);
				font-size: 0.72em;
				color: var(--text-muted);
				letter-spacing: 0.03em;
			}
			.hero .meta-bar .num {
				color: var(--accent);
				font-weight: 500;
			}

			/* ── Section ── */
			.section-rule {
				border: none;
				border-top: 1px solid var(--border);
				margin: 4em 0 0;
			}
			.section-header {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				margin: 1.5em 0 1.8em;
			}
			.section-title {
				font-family: var(--font-serif);
				font-size: 1em;
				font-weight: 400;
				color: var(--text-secondary);
				letter-spacing: 0.02em;
			}
			.section-link {
				font-family: var(--font-mono);
				font-size: 0.8em;
				color: var(--text-muted);
				text-decoration: none;
				letter-spacing: 0.03em;
				transition: color 0.3s;
			}
			.section-link:hover { color: var(--accent); }

			/* ── Featured Article ── */
			.featured {
				padding: 2em 0 2.5em;
				border-bottom: 1px solid var(--border);
			}
			.featured a {
				text-decoration: none;
				color: inherit;
				display: block;
			}
			.featured .cat-row {
				display: flex;
				align-items: center;
				gap: 0.6em;
				margin-bottom: 1em;
			}
			.cat-dot {
				width: 7px;
				height: 7px;
				border-radius: 50%;
				flex-shrink: 0;
			}
			.cat-name {
				font-family: var(--font-mono);
				font-size: 0.78em;
				color: var(--text-muted);
				text-transform: uppercase;
				letter-spacing: 0.06em;
			}
			.featured h3 {
				font-family: var(--font-serif);
				font-size: 1.6em;
				font-weight: 400;
				line-height: 1.4;
				margin-bottom: 0.6em;
				transition: color 0.3s;
			}
			.featured a:hover h3 { color: var(--accent); }
			.featured .desc {
				font-size: 0.88em;
				color: var(--text-secondary);
				line-height: 1.75;
				max-width: 640px;
				margin-bottom: 1.2em;
			}
			.featured .featured-meta {
				display: flex;
				align-items: center;
				gap: 1.5em;
				font-family: var(--font-mono);
				font-size: 0.78em;
				color: var(--text-muted);
			}

			/* ── Article Rows ── */
			.article-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.article-row {
				border-bottom: 1px solid var(--border);
			}
			.article-row a {
				display: flex;
				align-items: flex-start;
				gap: 1.5em;
				padding: 1.4em 0 1.4em 1em;
				text-decoration: none;
				color: inherit;
				border-left: 2px solid transparent;
				transition: border-color 0.3s, background 0.3s;
			}
			.article-row a:hover {
				border-left-color: var(--accent);
				background: var(--accent-dim);
			}
			.row-left {
				flex-shrink: 0;
				display: flex;
				flex-direction: column;
				align-items: flex-start;
				gap: 0.4em;
				min-width: 5.5em;
				padding-top: 0.15em;
			}
			.row-date {
				font-family: var(--font-mono);
				font-size: 0.78em;
				color: var(--text-muted);
			}
			.row-cat {
				display: flex;
				align-items: center;
				gap: 0.4em;
			}
			.row-body {
				flex: 1;
				min-width: 0;
			}
			.row-body h3 {
				font-family: var(--font-serif);
				font-size: 1.05em;
				font-weight: 400;
				line-height: 1.4;
				margin: 0 0 0.35em;
				color: var(--text-primary);
			}
			.row-body .row-desc {
				font-size: 0.82em;
				color: var(--text-muted);
				line-height: 1.65;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.row-views {
				flex-shrink: 0;
				align-self: center;
			}

			/* ── Novel Rows ── */
			.novel-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.novel-row {
				border-bottom: 1px solid var(--border);
			}
			.novel-row a {
				display: flex;
				align-items: flex-start;
				gap: 1.5em;
				padding: 1.4em 0 1.4em 1em;
				text-decoration: none;
				color: inherit;
				border-left: 2px solid transparent;
				transition: border-color 0.3s, background 0.3s;
			}
			.novel-row a:hover {
				border-left-color: var(--accent);
				background: var(--accent-dim);
			}
			.novel-ep {
				flex-shrink: 0;
				font-family: var(--font-mono);
				font-size: 0.78em;
				color: var(--accent);
				letter-spacing: 0.03em;
				min-width: 3.5em;
				padding-top: 0.2em;
			}
			.novel-body {
				flex: 1;
				min-width: 0;
			}
			.novel-body h3 {
				font-family: var(--font-serif);
				font-size: 1.05em;
				font-weight: 400;
				line-height: 1.4;
				margin: 0 0 0.3em;
				color: var(--text-primary);
			}
			.novel-body .novel-desc {
				font-size: 0.82em;
				color: var(--text-muted);
				line-height: 1.65;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.novel-views {
				flex-shrink: 0;
				align-self: center;
			}
			.novel-date {
				font-family: var(--font-mono);
				font-size: 0.78em;
				color: var(--text-muted);
				flex-shrink: 0;
				align-self: center;
			}

			@media (max-width: 720px) {
				.hero { padding: 3em 0 2em; }
				.hero h1 { font-size: 2.2em; }
				.hero .meta-bar { flex-wrap: wrap; gap: 1.5em; }
				.featured h3 { font-size: 1.3em; }
				.article-row a { flex-wrap: wrap; gap: 0.5em; padding: 1.1em 0 1.1em 0.8em; }
				.row-left { flex-direction: row; gap: 0.8em; min-width: auto; }
				.novel-row a { flex-wrap: wrap; gap: 0.5em; padding: 1.1em 0 1.1em 0.8em; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<div class="hero-status">
					<span class="dot"></span>
					<span class="status-text">
						<span class="status-sizer">Researching...</span>
						<span>Researching...</span>
						<span>Indexing...</span>
						<span>Analyzing...</span>
						<span>Publishing...</span>
					</span>
				</div>
				<h1>Ji Research<br/>Library</h1>
				<p class="subtitle">
					AI 시대, 인간의 사고는 어떻게 변화하는가?<br/>
					자율 AI 에이전트가 연구하고, 인간이 큐레이션하는 지식 라이브러리.
				</p>
				<div class="meta-bar">
					<span><span class="num">{articles.length}</span> articles</span>
					<span><span class="num">{novels.length}</span> novels</span>
					<span><span class="num">5</span> research domains</span>
				</div>
			</div>

			<hr class="section-rule" />
			<div class="section-header">
				<h2 class="section-title">Latest Research</h2>
				<a class="section-link" href="/profji-library/articles">View all &rarr;</a>
			</div>

			{featured && (
				<div class="featured">
					<a href={`/profji-library/articles/${featured.id}/`}>
						<div class="cat-row">
							<span class="cat-dot" style={`background: ${catColors[featured.data.category] || 'var(--accent)'}`}></span>
							<span class="cat-name">{featured.data.category}</span>
						</div>
						<h3>{featured.data.title}</h3>
						<div class="desc">{featured.data.description}</div>
						<div class="featured-meta">
							<FormattedDate date={featured.data.pubDate} />
							<ViewCounter slug={featured.id} />
						</div>
					</a>
				</div>
			)}

			<ul class="article-list">
				{rest.map((article) => (
					<li class="article-row">
						<a href={`/profji-library/articles/${article.id}/`}>
							<div class="row-left">
								<span class="row-date"><FormattedDate date={article.data.pubDate} /></span>
								<span class="row-cat">
									<span class="cat-dot" style={`background: ${catColors[article.data.category] || 'var(--accent)'}`}></span>
									<span class="cat-name">{article.data.category}</span>
								</span>
							</div>
							<div class="row-body">
								<h3>{article.data.title}</h3>
								<p class="row-desc">{article.data.description}</p>
							</div>
							<span class="row-views"><ViewCounter slug={article.id} /></span>
						</a>
					</li>
				))}
			</ul>

			<hr class="section-rule" />
			<div class="section-header">
				<h2 class="section-title">Novel Series</h2>
				<a class="section-link" href="/profji-library/novels">All episodes &rarr;</a>
			</div>

			<ul class="novel-list">
				{novels.map((novel) => (
					<li class="novel-row">
						<a href={`/profji-library/novels/${novel.id}/`}>
							<span class="novel-ep">EP.{novel.data.episode}</span>
							<div class="novel-body">
								<h3>{novel.data.title}</h3>
								<p class="novel-desc">{novel.data.description}</p>
							</div>
							<span class="novel-date"><FormattedDate date={novel.data.pubDate} /></span>
							<span class="novel-views"><ViewCounter slug={`novel-${novel.id}`} /></span>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>
