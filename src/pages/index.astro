---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import ViewCounter from '../components/ViewCounter.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const articles = (await getCollection('articles')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const novels = (await getCollection('novels')).sort(
	(a, b) => a.data.episode - b.data.episode,
);

const catColors: Record<string, string> = {
	'AI 심리학': 'var(--cat-psychology)',
	'인지 융합': 'var(--cat-cognition)',
	'AI 기술': 'var(--cat-tech)',
	'에이전트': 'var(--cat-agent)',
	'LLM 아키텍처': 'var(--cat-tech)',
};

const typeLabels: Record<string, string> = {
	'research synthesis': 'Research Synthesis',
	'framework': 'Framework',
	'essay': 'Essay',
	'analysis': 'Analysis',
	'case study': 'Case Study',
};

function readingTime(body: string): number {
	const chars = body.replace(/[#\-*_\[\]()>`~|]/g, '').replace(/\s+/g, '').length;
	return Math.max(1, Math.ceil(chars / 500));
}

import { SUPABASE_URL, supabaseHeaders } from '../lib/supabase';

let viewCounts: Record<string, number> = {};
try {
	const res = await fetch(`${SUPABASE_URL}/rest/v1/page_views?select=slug,count`, {
		headers: supabaseHeaders(),
	});
	if (res.ok) {
		const data: { slug: string; count: number }[] = await res.json();
		for (const row of data) viewCounts[row.slug] = row.count;
	}
} catch { /* fallback to date sort */ }

// Lead = newest article, secondary grid = top 3 by views (excluding lead)
const leadFeatured = articles[0]; // articles already sorted by pubDate desc
const restFeatured = [...articles]
	.filter((a) => a.id !== leadFeatured?.id)
	.sort((a, b) => (viewCounts[b.id] || 0) - (viewCounts[a.id] || 0))
	.slice(0, 3);
const heroSet = new Set([leadFeatured?.id, ...restFeatured.map((a) => a.id)]);
const archiveArticles = articles
	.filter((a) => !heroSet.has(a.id))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* ── Hero ── */
			.hero {
				padding: 6em 0 3em;
			}
			.hero-status {
				display: inline-flex;
				align-items: center;
				gap: 0.5em;
				font-family: var(--font-mono);
				font-size: 0.72em;
				color: var(--text-muted);
				letter-spacing: 0.06em;
				text-transform: uppercase;
				margin-bottom: 2.5em;
				position: relative;
				height: 1.4em;
			}
			.hero-status .dot {
				width: 5px;
				height: 5px;
				background: var(--accent);
				border-radius: 50%;
				animation: breathe 3s ease-in-out infinite;
				flex-shrink: 0;
			}
			.status-text {
				position: relative;
				display: inline-block;
			}
			.status-text span {
				position: absolute;
				left: 0;
				top: 0;
				white-space: nowrap;
				opacity: 0;
				animation: statusCycle 8s ease-in-out infinite;
			}
			.status-text span:nth-child(1) { animation-delay: 0s; }
			.status-text span:nth-child(2) { animation-delay: 2s; }
			.status-text span:nth-child(3) { animation-delay: 4s; }
			.status-text span:nth-child(4) { animation-delay: 6s; }
			.status-text .status-sizer {
				position: relative;
				visibility: hidden;
			}
			.hero h1 {
				font-size: 3em;
				font-weight: 300;
				letter-spacing: -0.03em;
				line-height: 1.1;
				margin-bottom: 0.6em;
			}
			.hero-thesis {
				font-family: var(--font-serif);
				font-size: 1.15em;
				font-weight: 400;
				color: var(--text-secondary);
				line-height: 1.6;
				max-width: 480px;
				margin-bottom: 0.6em;
			}
			.hero-sub {
				font-family: var(--font-mono);
				font-size: 0.76em;
				color: var(--text-muted);
				letter-spacing: 0.02em;
				line-height: 1.7;
				max-width: 520px;
			}
			.hero .meta-bar {
				margin-top: 2.5em;
				padding-top: 1.5em;
				border-top: 1px solid var(--border);
				display: flex;
				gap: 2.5em;
				font-family: var(--font-mono);
				font-size: 0.68em;
				color: var(--text-muted);
				letter-spacing: 0.04em;
				text-transform: uppercase;
			}
			.hero .meta-bar .num {
				color: var(--accent);
				font-weight: 500;
			}

			/* ── Section ── */
			.section-rule {
				border: none;
				border-top: 1px solid var(--border);
				margin: 4em 0 0;
			}
			.section-header {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				margin: 2em 0 0.6em;
			}
			.section-title {
				font-family: var(--font-mono);
				font-size: 0.72em;
				font-weight: 400;
				color: var(--text-muted);
				letter-spacing: 0.08em;
				text-transform: uppercase;
			}
			.section-link {
				font-family: var(--font-mono);
				font-size: 0.68em;
				color: var(--text-muted);
				text-decoration: none;
				letter-spacing: 0.04em;
				text-transform: uppercase;
				transition: color 0.3s;
			}
			.section-link:hover { color: var(--accent); }

			/* ── Type Badge ── */
			.type-badge {
				font-family: var(--font-mono);
				font-size: 0.62em;
				color: var(--accent);
				letter-spacing: 0.05em;
				text-transform: uppercase;
				border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent);
				padding: 0.1em 0.45em;
				border-radius: 2px;
				white-space: nowrap;
			}
			.reading-time {
				font-family: var(--font-mono);
				font-size: 0.68em;
				color: var(--text-muted);
				letter-spacing: 0.03em;
			}
			.cat-dot {
				width: 6px;
				height: 6px;
				border-radius: 50%;
				flex-shrink: 0;
			}
			.cat-name {
				font-family: var(--font-mono);
				font-size: 0.68em;
				color: var(--text-muted);
				letter-spacing: 0.06em;
			}

			/* ── Featured: Lead Card ── */
			.featured-lead {
				padding: 2em 0;
				border-bottom: 1px solid var(--border);
			}
			.featured-lead a {
				text-decoration: none;
				color: inherit;
				display: block;
			}
			.featured-lead .lead-meta {
				display: flex;
				align-items: center;
				gap: 0.8em;
				margin-bottom: 1.2em;
			}
			.featured-lead h3 {
				font-family: var(--font-serif);
				font-size: 1.5em;
				font-weight: 400;
				line-height: 1.35;
				margin-bottom: 0.4em;
				transition: color 0.3s;
			}
			.featured-lead a:hover h3 { color: var(--accent); }
			.featured-lead .lead-title-en {
				font-family: var(--font-mono);
				font-size: 0.72em;
				color: var(--text-muted);
				letter-spacing: 0.01em;
				margin-bottom: 0.8em;
				line-height: 1.5;
			}
			.featured-lead .lead-desc {
				font-size: 0.85em;
				color: var(--text-secondary);
				line-height: 1.7;
				max-width: 600px;
				margin-bottom: 1em;
			}
			.featured-lead .lead-footer {
				display: flex;
				align-items: center;
				gap: 1.2em;
				font-family: var(--font-mono);
				font-size: 0.68em;
				color: var(--text-muted);
			}

			/* ── Featured: Secondary Grid ── */
			.featured-secondary {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 0;
			}
			.featured-sec-card {
				padding: 1.5em 1.5em 1.5em 0;
				border-bottom: 1px solid var(--border);
			}
			.featured-sec-card + .featured-sec-card {
				padding-left: 1.5em;
				border-left: 1px solid var(--border);
			}
			.featured-sec-card a {
				text-decoration: none;
				color: inherit;
				display: block;
				height: 100%;
			}
			.featured-sec-card .sec-meta {
				display: flex;
				align-items: center;
				gap: 0.6em;
				margin-bottom: 0.8em;
			}
			.featured-sec-card h4 {
				font-family: var(--font-serif);
				font-size: 0.95em;
				font-weight: 400;
				line-height: 1.4;
				margin: 0 0 0.3em;
				color: var(--text-primary);
				transition: color 0.3s;
			}
			.featured-sec-card a:hover h4 { color: var(--accent); }
			.featured-sec-card .sec-title-en {
				font-family: var(--font-mono);
				font-size: 0.64em;
				color: var(--text-muted);
				letter-spacing: 0.01em;
				line-height: 1.45;
				margin-bottom: 0.5em;
			}
			.featured-sec-card .sec-footer {
				display: flex;
				align-items: center;
				gap: 0.8em;
				margin-top: auto;
				font-family: var(--font-mono);
				font-size: 0.64em;
				color: var(--text-muted);
			}

			/* ── Archive Index ── */
			.archive-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.archive-item {
				border-bottom: 1px solid var(--border);
			}
			.archive-item a {
				display: flex;
				align-items: baseline;
				gap: 1.2em;
				padding: 0.9em 0;
				text-decoration: none;
				color: inherit;
				transition: background 0.2s;
			}
			.archive-item a:hover {
				background: var(--accent-dim);
			}
			.archive-item a:hover .archive-title {
				color: var(--accent);
			}
			.archive-date {
				font-family: var(--font-mono);
				font-size: 0.68em;
				color: var(--text-muted);
				letter-spacing: 0.02em;
				flex-shrink: 0;
				width: 7.5em;
			}
			.archive-cat {
				display: flex;
				align-items: center;
				gap: 0.35em;
				flex-shrink: 0;
				width: 6.5em;
			}
			.archive-title {
				font-family: var(--font-serif);
				font-size: 0.92em;
				font-weight: 400;
				line-height: 1.35;
				color: var(--text-primary);
				flex: 1;
				min-width: 0;
				transition: color 0.3s;
			}
			.archive-meta {
				display: flex;
				align-items: center;
				gap: 0.8em;
				flex-shrink: 0;
				min-width: 14em;
				justify-content: flex-end;
			}

			/* ── Novel Rows ── */
			.novel-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.novel-row {
				border-bottom: 1px solid var(--border);
			}
			.novel-row a {
				display: flex;
				align-items: baseline;
				gap: 1.2em;
				padding: 0.9em 0;
				text-decoration: none;
				color: inherit;
				transition: background 0.2s;
			}
			.novel-row a:hover {
				background: var(--accent-dim);
			}
			.novel-row a:hover .novel-title {
				color: var(--accent);
			}
			.novel-ep {
				flex-shrink: 0;
				font-family: var(--font-mono);
				font-size: 0.68em;
				color: var(--accent);
				letter-spacing: 0.04em;
				min-width: 3.5em;
			}
			.novel-title {
				font-family: var(--font-serif);
				font-size: 0.92em;
				font-weight: 400;
				line-height: 1.35;
				color: var(--text-primary);
				flex: 1;
				min-width: 0;
				transition: color 0.3s;
			}
			.novel-meta {
				display: flex;
				align-items: center;
				gap: 0.8em;
				flex-shrink: 0;
			}
			.novel-date {
				font-family: var(--font-mono);
				font-size: 0.68em;
				color: var(--text-muted);
			}

			/* ── Responsive ── */
			@media (max-width: 720px) {
				.hero { padding: 4em 0 2em; }
				.hero h1 { font-size: 2.4em; }
				.hero-thesis { font-size: 1.05em; }
				.hero .meta-bar { flex-wrap: wrap; gap: 1.2em 2em; }

				.featured-lead h3 { font-size: 1.25em; }

				.featured-secondary {
					grid-template-columns: 1fr;
					gap: 0;
				}
				.featured-sec-card {
					padding: 1.2em 0;
				}
				.featured-sec-card + .featured-sec-card {
					padding-left: 0;
					border-left: none;
				}

				.archive-item a {
					flex-wrap: wrap;
					gap: 0.3em 0.8em;
					padding: 0.8em 0;
				}
				.archive-date { min-width: auto; }
				.archive-title {
					flex-basis: 100%;
					order: 3;
				}
				.archive-meta {
					flex-basis: 100%;
					order: 4;
				}

				.novel-row a {
					flex-wrap: wrap;
					gap: 0.3em 0.8em;
					padding: 0.8em 0;
				}
				.novel-title { flex-basis: 100%; }
			}

			/* ── Card Tilt ── */
			.featured-sec-card {
				will-change: transform;
				transition: transform 0.18s ease, border-color 0.3s ease;
			}

			/* ── Archive accent bar ── */
			.archive-item a {
				position: relative;
				padding-left: 0.75em;
			}
			.archive-item a::before {
				content: '';
				position: absolute;
				left: 0;
				top: 50%;
				transform: translateY(-50%) scaleY(0);
				width: 2px;
				height: 55%;
				background: var(--accent);
				border-radius: 1px;
				transition: transform 0.2s ease;
			}
			.archive-item a:hover::before {
				transform: translateY(-50%) scaleY(1);
			}

			/* ── Novel accent bar ── */
			.novel-row a {
				position: relative;
				padding-left: 0.75em;
			}
			.novel-row a::before {
				content: '';
				position: absolute;
				left: 0;
				top: 50%;
				transform: translateY(-50%) scaleY(0);
				width: 2px;
				height: 55%;
				background: var(--accent);
				border-radius: 1px;
				transition: transform 0.2s ease;
			}
			.novel-row a:hover::before {
				transform: translateY(-50%) scaleY(1);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<div class="hero-status">
					<span class="dot"></span>
					<span class="status-text">
						<span class="status-sizer">Researching...</span>
						<span>Researching...</span>
						<span>Structuring...</span>
						<span>Reviewing...</span>
						<span>Publishing...</span>
					</span>
				</div>
				<h1>Ji Research<br/>Library</h1>
				<p class="hero-thesis">
					AI와 함께 일할 때 인간의 인지는 어떻게 변하는가?
				</p>
				<p class="hero-sub">
					AI, cognition, and agent systems — researched with AI, published under human judgment.
				</p>

				<div class="meta-bar">
					<span><span class="num">{articles.length}</span> essays</span>
					<span><span class="num">5</span> research axes</span>
					<span>human-curated</span>
				</div>
			</div>

			{articles.length > 0 && (
				<>
					<hr class="section-rule" />
					<div class="section-header">
						<h2 class="section-title">Start Here</h2>
					</div>

					{leadFeatured && (
						<div class="featured-lead">
							<a href={`/profji-library/articles/${leadFeatured.id}/`}>
								<div class="lead-meta">
									<span class="cat-dot" style={`background: ${catColors[leadFeatured.data.category] || 'var(--accent)'}`}></span>
									<span class="cat-name">{leadFeatured.data.category}</span>
									<span class="type-badge">{typeLabels[leadFeatured.data.articleType] || leadFeatured.data.articleType}</span>
								</div>
								<h3>{leadFeatured.data.title}</h3>
								{leadFeatured.data.titleEn && <p class="lead-title-en">{leadFeatured.data.titleEn}</p>}
								<p class="lead-desc">{leadFeatured.data.description}</p>
								<div class="lead-footer">
									<span class="reading-time">{readingTime(leadFeatured.body || '')} min read</span>
									<ViewCounter slug={leadFeatured.id} />
								</div>
							</a>
						</div>
					)}

					{restFeatured.length > 0 && (
						<div class="featured-secondary">
							{restFeatured.map((article) => (
								<div class="featured-sec-card">
									<a href={`/profji-library/articles/${article.id}/`}>
										<div class="sec-meta">
											<span class="cat-dot" style={`background: ${catColors[article.data.category] || 'var(--accent)'}`}></span>
											<span class="cat-name">{article.data.category}</span>
										</div>
										<h4>{article.data.title}</h4>
										{article.data.titleEn && <p class="sec-title-en">{article.data.titleEn}</p>}
										<div class="sec-footer">
											<span class="type-badge">{typeLabels[article.data.articleType] || article.data.articleType}</span>
											<span class="reading-time">{readingTime(article.body || '')} min</span>
										</div>
									</a>
								</div>
							))}
						</div>
					)}
				</>
			)}

			<hr class="section-rule" />
			<div class="section-header">
				<h2 class="section-title">Archive</h2>
				<a class="section-link" href="/profji-library/articles">View all &rarr;</a>
			</div>

			<ul class="archive-list">
				{archiveArticles.map((article) => (
					<li class="archive-item">
						<a href={`/profji-library/articles/${article.id}/`}>
							<span class="archive-date"><FormattedDate date={article.data.pubDate} /></span>
							<span class="archive-cat">
								<span class="cat-dot" style={`background: ${catColors[article.data.category] || 'var(--accent)'}`}></span>
								<span class="cat-name">{article.data.category}</span>
							</span>
							<span class="archive-title">{article.data.title}</span>
							<span class="archive-meta">
								<span class="type-badge">{typeLabels[article.data.articleType] || article.data.articleType}</span>
								<span class="reading-time">{readingTime(article.body || '')} min</span>
								<ViewCounter slug={article.id} />
							</span>
						</a>
					</li>
				))}
			</ul>

			<hr class="section-rule" />
			<div class="section-header">
				<h2 class="section-title">Narrative Lab</h2>
				<a class="section-link" href="/profji-library/novels">All episodes &rarr;</a>
			</div>

			<ul class="novel-list">
				{novels.map((novel) => (
					<li class="novel-row">
						<a href={`/profji-library/novels/${novel.id}/`}>
							<span class="novel-ep">EP.{novel.data.episode}</span>
							<span class="novel-title">{novel.data.title}</span>
							<span class="novel-meta">
								<span class="novel-date"><FormattedDate date={novel.data.pubDate} /></span>
								<ViewCounter slug={`novel-${novel.id}`} />
							</span>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
		<script>
			// 3D tilt on secondary featured cards
			document.querySelectorAll('.featured-sec-card').forEach(function(card) {
				card.addEventListener('mousemove', function(e) {
					var rect = card.getBoundingClientRect();
					var x = (e.clientX - rect.left) / rect.width - 0.5;
					var y = (e.clientY - rect.top) / rect.height - 0.5;
					card.style.transform = 'perspective(700px) rotateX(' + (-y * 7) + 'deg) rotateY(' + (x * 7) + 'deg)';
				});
				card.addEventListener('mouseleave', function() {
					card.style.transform = '';
				});
			});
		</script>
	</body>
</html>
