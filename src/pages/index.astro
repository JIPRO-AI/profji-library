---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const articles = (await getCollection('articles')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const novels = (await getCollection('novels')).sort(
	(a, b) => a.data.episode - b.data.episode,
);

const catColors: Record<string, string> = {
	'AI 심리학': 'var(--cat-psychology)',
	'인지 융합': 'var(--cat-cognition)',
	'AI 기술': 'var(--cat-tech)',
	'에이전트': 'var(--cat-agent)',
};

const featured = articles[0];
const rest = articles.slice(1, 6);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* ── Hero ── */
			.hero {
				padding: 5em 0 3em;
			}
			.hero-status {
				display: inline-flex;
				align-items: center;
				gap: 0.5em;
				font-family: var(--font-mono);
				font-size: 0.7em;
				color: var(--text-muted);
				letter-spacing: 0.05em;
				text-transform: uppercase;
				margin-bottom: 2em;
			}
			.hero-status .dot {
				width: 5px;
				height: 5px;
				background: var(--accent);
				border-radius: 50%;
				animation: breathe 3s ease-in-out infinite;
			}
			.hero h1 {
				font-size: 3.2em;
				font-weight: 300;
				letter-spacing: -0.03em;
				line-height: 1.15;
				margin-bottom: 0.4em;
			}
			.hero .subtitle {
				color: var(--text-secondary);
				font-size: 1.05em;
				line-height: 1.75;
				max-width: 540px;
			}
			.hero .meta-bar {
				margin-top: 2.5em;
				padding-top: 1.5em;
				border-top: 1px solid var(--border);
				display: flex;
				gap: 2.5em;
				font-family: var(--font-mono);
				font-size: 0.72em;
				color: var(--text-muted);
				letter-spacing: 0.03em;
			}
			.hero .meta-bar .num {
				color: var(--accent);
				font-weight: 500;
			}

			/* ── Section ── */
			.section-rule {
				border: none;
				border-top: 1px solid var(--border);
				margin: 4em 0 0;
			}
			.section-header {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				margin: 1.5em 0 1.8em;
			}
			.section-title {
				font-family: var(--font-serif);
				font-size: 1em;
				font-weight: 400;
				color: var(--text-secondary);
				letter-spacing: 0.02em;
			}
			.section-link {
				font-family: var(--font-mono);
				font-size: 0.7em;
				color: var(--text-muted);
				text-decoration: none;
				letter-spacing: 0.03em;
				transition: color 0.3s;
			}
			.section-link:hover { color: var(--accent); }

			/* ── Article Grid ── */
			.article-layout {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1px;
				background: var(--border);
				border-radius: 2px;
				overflow: hidden;
			}
			.featured-card {
				grid-row: 1 / 4;
				background: var(--bg-card);
				padding: 2em;
				transition: background 0.3s ease;
			}
			.featured-card:hover { background: var(--bg-card-hover); }
			.featured-card a {
				text-decoration: none;
				color: inherit;
				display: flex;
				flex-direction: column;
				height: 100%;
			}
			.featured-card .card-cat {
				display: flex;
				align-items: center;
				gap: 0.6em;
				margin-bottom: 1.2em;
			}
			.cat-dot {
				width: 7px;
				height: 7px;
				border-radius: 50%;
				flex-shrink: 0;
			}
			.cat-name {
				font-family: var(--font-mono);
				font-size: 0.68em;
				color: var(--text-muted);
				text-transform: uppercase;
				letter-spacing: 0.06em;
			}
			.featured-card h3 {
				font-family: var(--font-serif);
				font-size: 1.4em;
				font-weight: 400;
				line-height: 1.45;
				margin-bottom: 0.8em;
				color: var(--text-primary);
			}
			.featured-card .desc {
				font-size: 0.85em;
				color: var(--text-secondary);
				line-height: 1.75;
				flex: 1;
			}
			.featured-card .card-date {
				font-family: var(--font-mono);
				font-size: 0.68em;
				color: var(--text-muted);
				margin-top: 1.5em;
			}

			/* ── Compact Cards ── */
			.compact-card {
				background: var(--bg-card);
				padding: 1.3em 1.5em;
				transition: background 0.3s ease;
			}
			.compact-card:hover { background: var(--bg-card-hover); }
			.compact-card a { text-decoration: none; color: inherit; display: block; }
			.compact-card .card-top {
				display: flex;
				align-items: center;
				gap: 0.6em;
				margin-bottom: 0.4em;
			}
			.compact-card .card-date {
				font-family: var(--font-mono);
				font-size: 0.68em;
				color: var(--text-muted);
				margin-left: auto;
			}
			.compact-card h3 {
				font-family: var(--font-serif);
				font-size: 0.95em;
				font-weight: 400;
				line-height: 1.45;
				color: var(--text-primary);
				margin: 0;
			}

			/* ── Novels ── */
			.novel-list { display: grid; }
			.novel-item {
				display: flex;
				align-items: baseline;
				gap: 1.5em;
				padding: 1.2em 0;
				border-bottom: 1px solid var(--border);
				text-decoration: none;
				color: inherit;
				transition: padding-left 0.3s ease;
			}
			.novel-item:last-child { border-bottom: none; }
			.novel-item:hover { padding-left: 0.5em; }
			.novel-ep {
				font-family: var(--font-mono);
				font-size: 0.72em;
				color: var(--accent);
				letter-spacing: 0.03em;
				flex-shrink: 0;
				min-width: 3em;
			}
			.novel-title {
				font-family: var(--font-serif);
				font-size: 1em;
				font-weight: 400;
				color: var(--text-primary);
			}
			.novel-desc {
				font-size: 0.82em;
				color: var(--text-muted);
				margin-left: auto;
				text-align: right;
				flex-shrink: 0;
				max-width: 280px;
			}

			@media (max-width: 720px) {
				.hero { padding: 3em 0 2em; }
				.hero h1 { font-size: 2.2em; }
				.hero .meta-bar { flex-wrap: wrap; gap: 1.5em; }
				.article-layout { grid-template-columns: 1fr; }
				.featured-card { grid-row: auto; }
				.novel-item { flex-direction: column; gap: 0.3em; }
				.novel-desc { margin-left: 0; text-align: left; max-width: none; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<div class="hero-status">
					<span class="dot"></span>
					Autonomous Research Active
				</div>
				<h1>Ji Research<br/>Library</h1>
				<p class="subtitle">
					AI 시대, 인간의 사고는 어떻게 변화하는가?<br/>
					자율 AI 에이전트가 연구하고, 인간이 큐레이션하는 지식 라이브러리.
				</p>
				<div class="meta-bar">
					<span><span class="num">{articles.length}</span> articles</span>
					<span><span class="num">{novels.length}</span> novels</span>
					<span><span class="num">4</span> research domains</span>
				</div>
			</div>

			<hr class="section-rule" />
			<div class="section-header">
				<h2 class="section-title">Latest Research</h2>
				<a class="section-link" href="/profji-library/articles">View all &rarr;</a>
			</div>

			<div class="article-layout">
				{featured && (
					<div class="featured-card">
						<a href={`/profji-library/articles/${featured.id}/`}>
							<div class="card-cat">
								<span class="cat-dot" style={`background: ${catColors[featured.data.category] || 'var(--accent)'}`}></span>
								<span class="cat-name">{featured.data.category}</span>
							</div>
							<h3>{featured.data.title}</h3>
							<div class="desc">{featured.data.description}</div>
							<div class="card-date"><FormattedDate date={featured.data.pubDate} /></div>
						</a>
					</div>
				)}
				{rest.map((article) => (
					<div class="compact-card">
						<a href={`/profji-library/articles/${article.id}/`}>
							<div class="card-top">
								<span class="cat-dot" style={`background: ${catColors[article.data.category] || 'var(--accent)'}`}></span>
								<span class="cat-name">{article.data.category}</span>
								<span class="card-date"><FormattedDate date={article.data.pubDate} /></span>
							</div>
							<h3>{article.data.title}</h3>
						</a>
					</div>
				))}
			</div>

			<hr class="section-rule" />
			<div class="section-header">
				<h2 class="section-title">Novel Series</h2>
				<a class="section-link" href="/profji-library/novels">All episodes &rarr;</a>
			</div>

			<div class="novel-list">
				{novels.map((novel) => (
					<a class="novel-item" href={`/profji-library/novels/${novel.id}/`}>
						<span class="novel-ep">EP.{novel.data.episode}</span>
						<span class="novel-title">{novel.data.title}</span>
						<span class="novel-desc">{novel.data.description}</span>
					</a>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>
