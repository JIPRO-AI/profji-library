---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`About | ${SITE_TITLE}`} description="AI랑 같이 일할 때 사람의 판단이 어떻게 바뀌는지 기록합니다." />
		<style>
			/* ── Header ── */
			.about-header {
				padding: 5em 0 3em;
			}
			.about-header .label {
				font-family: var(--font-mono);
				font-size: 0.68em;
				color: var(--text-muted);
				text-transform: uppercase;
				letter-spacing: 0.08em;
				margin-bottom: 1.5em;
				display: block;
			}
			.about-header h1 {
				font-size: 2.8em;
				font-weight: 300;
				letter-spacing: -0.02em;
				margin-bottom: 0.4em;
			}
			.about-header .tagline {
				font-family: var(--font-serif);
				font-size: 1.15em;
				color: var(--text-secondary);
				font-style: italic;
				line-height: 1.7;
				max-width: 480px;
				margin-bottom: 1.5em;
			}
			.about-header .manifesto {
				font-size: 0.88em;
				color: var(--text-secondary);
				line-height: 1.9;
				max-width: 540px;
			}

			/* ── Sections ── */
			.about-section {
				padding: 3em 0;
				border-top: 1px solid var(--border);
			}
			.about-section h2 {
				font-family: var(--font-mono);
				font-size: 0.72em;
				font-weight: 400;
				color: var(--text-muted);
				letter-spacing: 0.08em;
				text-transform: uppercase;
				margin-bottom: 1.5em;
			}
			.about-section p {
				color: var(--text-secondary);
				max-width: 560px;
				line-height: 1.9;
			}
			.purpose-lead {
				font-family: var(--font-serif);
				font-size: 1.05em;
				color: var(--text-primary);
				line-height: 1.8;
				max-width: 560px;
				margin-bottom: 1em;
			}
			.purpose-body {
				font-size: 0.88em;
				color: var(--text-secondary);
				line-height: 1.9;
				max-width: 560px;
			}

			/* ── Fields of Inquiry ── */
			.field-intro {
				font-size: 0.85em;
				color: var(--text-muted);
				line-height: 1.7;
				max-width: 520px;
				margin-bottom: 2em;
			}
			.domain-grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 0;
			}
			.domain-card {
				padding: 1.8em 1.8em 1.8em 0;
				border-bottom: 1px solid var(--border);
			}
			.domain-card:nth-child(even) {
				padding-left: 1.8em;
				border-left: 1px solid var(--border);
			}
			.domain-card:nth-child(-n+2) {
				border-top: 1px solid var(--border);
			}
			.domain-dot {
				width: 8px;
				height: 8px;
				border-radius: 50%;
				flex-shrink: 0;
				display: inline-block;
				margin-bottom: 0.8em;
			}
			.domain-name {
				font-family: var(--font-serif);
				font-weight: 600;
				font-size: 1.05em;
				color: var(--text-primary);
				display: block;
				margin-bottom: 0.5em;
			}
			.domain-question {
				font-family: var(--font-serif);
				font-size: 0.82em;
				color: var(--text-secondary);
				font-style: italic;
				line-height: 1.6;
				margin-bottom: 0.6em;
			}
			.domain-keywords {
				font-family: var(--font-mono);
				font-size: 0.68em;
				color: var(--text-muted);
				letter-spacing: 0.02em;
				line-height: 1.5;
			}

			/* ── Production System ── */
			.process-intro {
				font-size: 0.88em;
				color: var(--text-secondary);
				line-height: 1.9;
				max-width: 560px;
				margin-bottom: 2.5em;
			}
			.pipeline-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 0;
			}
			.pipeline-card {
				padding: 1.5em;
				border: 1px solid var(--border);
				border-right: none;
				border-bottom: none;
			}
			.pipeline-card:nth-child(3n) {
				border-right: 1px solid var(--border);
			}
			.pipeline-card:nth-child(n+4) {
				/* bottom row already has top border from top row's bottom */
			}
			/* top row top border */
			.pipeline-card:nth-child(-n+3) {
				border-top: 1px solid var(--border);
			}
			/* bottom row bottom border */
			.pipeline-card:nth-child(n+4) {
				border-bottom: 1px solid var(--border);
			}
			.pipe-num {
				font-family: var(--font-mono);
				font-size: 0.62em;
				color: var(--text-muted);
				letter-spacing: 0.04em;
				display: block;
				margin-bottom: 0.6em;
			}
			.pipe-label {
				font-family: var(--font-mono);
				font-size: 0.78em;
				color: var(--text-primary);
				letter-spacing: 0.02em;
				font-weight: 500;
				display: block;
				margin-bottom: 0.4em;
			}
			.pipe-desc {
				font-size: 0.78em;
				color: var(--text-secondary);
				line-height: 1.6;
			}
			.pipe-agent {
				font-family: var(--font-mono);
				font-size: 0.62em;
				color: var(--text-muted);
				letter-spacing: 0.02em;
				display: block;
				margin-top: 0.6em;
			}
			.process-note {
				margin-top: 2em;
				font-size: 0.82em;
				color: var(--text-muted);
				line-height: 1.7;
				max-width: 540px;
			}

			/* ── Tech Stack ── */
			.tech-intro {
				font-size: 0.85em;
				color: var(--text-muted);
				line-height: 1.7;
				max-width: 520px;
				margin-bottom: 2em;
			}
			.tech-groups {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 0;
			}
			.tech-group {
				padding: 1.5em 1.5em 1.5em 0;
				border-bottom: 1px solid var(--border);
			}
			.tech-group:nth-child(even) {
				padding-left: 1.5em;
				border-left: 1px solid var(--border);
			}
			.tech-group:nth-child(-n+2) {
				border-top: 1px solid var(--border);
			}
			.tech-group-title {
				font-family: var(--font-mono);
				font-size: 0.68em;
				color: var(--accent);
				letter-spacing: 0.06em;
				text-transform: uppercase;
				margin-bottom: 0.8em;
			}
			.tech-group ul {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.tech-group li {
				font-size: 0.82em;
				color: var(--text-secondary);
				line-height: 1.5;
				padding: 0.2em 0;
				margin: 0;
			}
			.tech-role {
				font-family: var(--font-mono);
				font-size: 0.92em;
				color: var(--text-muted);
			}

			/* ── Closing ── */
			.closing {
				padding: 3em 0;
				border-top: 1px solid var(--border);
			}
			.closing-lead {
				font-family: var(--font-serif);
				font-size: 0.95em;
				color: var(--text-primary);
				line-height: 1.8;
				max-width: 540px;
				margin-bottom: 0.8em;
			}
			.closing p {
				font-size: 0.85em;
				color: var(--text-muted);
				line-height: 1.8;
				max-width: 540px;
			}

			/* ── Responsive ── */
			@media (max-width: 720px) {
				.about-header { padding: 3.5em 0 2em; }
				.about-header h1 { font-size: 2em; }
				.domain-grid { grid-template-columns: 1fr; }
				.domain-card {
					padding: 1.4em 0;
				}
				.domain-card:nth-child(even) {
					padding-left: 0;
					border-left: none;
				}
				.domain-card:nth-child(-n+2) {
					border-top: none;
				}
				.domain-card:first-child {
					border-top: 1px solid var(--border);
				}
				.pipeline-grid {
					grid-template-columns: 1fr;
				}
				.pipeline-card {
					border-right: 1px solid var(--border);
					border-bottom: none;
				}
				.pipeline-card:last-child {
					border-bottom: 1px solid var(--border);
				}
				.pipeline-card:nth-child(3n) {
					border-right: 1px solid var(--border);
				}
				.tech-groups { grid-template-columns: 1fr; }
				.tech-group {
					padding: 1.2em 0;
				}
				.tech-group:nth-child(even) {
					padding-left: 0;
					border-left: none;
				}
				.tech-group:nth-child(-n+2) {
					border-top: none;
				}
				.tech-group:first-child {
					border-top: 1px solid var(--border);
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<!-- ── 1층: 정체성 ── -->
			<div class="about-header">
				<span class="label">About</span>
				<h1>Ji Research Library</h1>
				<p class="tagline">AI와 같이 일할 때 인간의 판단이 어떻게 바뀌는지 기록합니다.</p>
				<p class="manifesto">
					이곳은 AI가 초안을 쓰고 사람이 승인만 누르는 블로그가 되지 않도록 만들었습니다. 글 하나를 올리기까지 여러 단계의 검증을 거치고 그 과정 자체도 함께 기록합니다.
				</p>
				<p class="manifesto">
					여기에 실린 글은 결과물이면서 동시에 실험 기록입니다.
					AI와 함께 글을 만들 때 판단이 어디서 달라지는지 자동화가 어디까지 가능하고 어디서부터 인간의 역할이 다시 중요해지는지 계속 시험합니다.
				</p>
			</div>

			<!-- ── Purpose ── -->
			<div class="about-section">
				<h2>Purpose</h2>
				<p class="purpose-lead">
					여기서는 AI가 인간을 대체하느냐 못 하느냐 같은 큰 주장만 반복하지 않습니다.
				</p>
				<p class="purpose-body">
					대신 더 구체적인 질문을 봅니다. AI와 함께 일할 때 판단 구조는 어떻게 바뀌는지 전문성의 기준은 어디로 이동하는지 무엇을 더 잘하게 되고 무엇을 잃게 되는지. 이 질문들을 논문 기반 에세이로 정리해 쌓아갑니다.
				</p>
			</div>

			<!-- ── 2층: 탐구 축 ── -->
			<div class="about-section">
				<h2>Fields of Inquiry</h2>
				<p class="field-intro">
					이 라이브러리는 네 가지 분야로 나뉘어 있습니다. 따로 보이지만 결국은 하나의 질문을 네 방향에서 보는 구조입니다. AI 시대에 인간의 머리는 어떻게 작동하는가.
				</p>
				<div class="domain-grid">
					<div class="domain-card">
						<span class="domain-dot" style="background: var(--cat-psychology)"></span>
						<span class="domain-name">AI 심리학</span>
						<div class="domain-question">AI 의존이 판단력을 강화하는지 약화시키는지</div>
						<div class="domain-keywords">자동화 편향 · 탈숙련화 · 과신 효과 · 전문성 변형</div>
					</div>
					<div class="domain-card">
						<span class="domain-dot" style="background: var(--cat-cognition)"></span>
						<span class="domain-name">인지 융합</span>
						<div class="domain-question">인간-AI 결합이 새로운 인지 모델을 만드는지</div>
						<div class="domain-keywords">하이브리드 마인드 · 확장된 인지 · 인간-AI 공동 추론</div>
					</div>
					<div class="domain-card">
						<span class="domain-dot" style="background: var(--cat-tech)"></span>
						<span class="domain-name">AI 기술</span>
						<div class="domain-question">LLM의 구조적 한계와 그것을 아는 이유</div>
						<div class="domain-keywords">환각 통제 · RAG 한계 · 컨텍스트 윈도우 · 로컬 LLM</div>
					</div>
					<div class="domain-card">
						<span class="domain-dot" style="background: var(--cat-agent)"></span>
						<span class="domain-name">에이전트</span>
						<div class="domain-question">여러 AI가 함께 일할 때 시스템이 좋아지거나 무너지는 조건</div>
						<div class="domain-keywords">멀티에이전트 · 오케스트레이션 · 오류 증폭 · 협력 임계점</div>
					</div>
				</div>
			</div>

			<!-- ── 3층: 생산 구조 ── -->
			<div class="about-section">
				<h2>Production System</h2>
				<p class="process-intro">
					에세이 하나가 공개되기까지는 6단계를 거칩니다.
					단계마다 역할이 다른 에이전트가 작업하고 품질 게이트가 다음 단계로 넘어갈지 결정합니다. 두 번 연속 게이트를 통과하지 못하면 글은 자동으로 중단되고 사람의 개입이 있어야 다시 시작할 수 있습니다.
				</p>
				<div class="pipeline-grid">
					<div class="pipeline-card">
						<span class="pipe-num">01</span>
						<span class="pipe-label">Thesis</span>
						<div class="pipe-desc">주제에서 구체적이고 논쟁 가능한 핵심 주장을 뽑아냅니다. '~이 중요하다'는 thesis가 아닙니다.</div>
						<span class="pipe-agent">Prof Ji (API)</span>
					</div>
					<div class="pipeline-card">
						<span class="pipe-num">02</span>
						<span class="pipe-label">Research</span>
						<div class="pipe-desc">arXiv, OpenAlex, CrossRef에서 관련 논문을 수집하고 아웃라인을 설계합니다.</div>
						<span class="pipe-agent">Researcher Ji (Qwen 3.6 35B MoE)</span>
					</div>
					<div class="pipeline-card">
						<span class="pipe-num">03</span>
						<span class="pipe-label">Evidence Pack</span>
						<div class="pipe-desc">수집된 논문을 SOURCE/CLAIM/DATA 형식으로 정리하고 각 근거를 어느 섹션에서 쓸지 매핑합니다.</div>
						<span class="pipe-agent">Prof Ji (API) → Gate 1</span>
					</div>
					<div class="pipeline-card">
						<span class="pipe-num">04</span>
						<span class="pipe-label">Draft</span>
						<div class="pipe-desc">Evidence Pack을 받아 에세이를 씁니다. Writer는 연구를 하지 않습니다. 글만 씁니다.</div>
						<span class="pipe-agent">Writer Ji (Nemotron-120B via NIM API) → Gate 2</span>
					</div>
					<div class="pipeline-card">
						<span class="pipe-num">05</span>
						<span class="pipe-label">Review</span>
						<div class="pipe-desc">5축 리뷰(사실 과장, 인용 불일치, 신규성 부풀림, 숨은 가정, 가독성). 주장별 SUPPORTED/INFERENCE/SPECULATION 분류.</div>
						<span class="pipe-agent">Reviewer Ji (Gemma 4 26B MoE) → Gate 3–4</span>
					</div>
					<div class="pipeline-card">
						<span class="pipe-num">06</span>
						<span class="pipe-label">Human Approval</span>
						<div class="pipe-desc">자동 그레이딩(A/B/C) 후 사람이 최종 구조, 논조, 배포 여부를 결정합니다. C등급은 큐로 돌아갑니다.</div>
						<span class="pipe-agent">Auto-grading → Human Editor</span>
					</div>
				</div>
				<p class="process-note">
					핵심은 역할을 섞지 않는 것입니다. 리서치하는 모델, 쓰는 모델, 검증하는 모델을 분리하고 특히 검증 모델은 작성 모델과 다른 계열로 둡니다. 같은 모델이 자기 출력을 스스로 무비판적으로 통과시키는 일을 막기 위해서입니다.
				</p>
			</div>

			<!-- ── 4층: 기술적 신뢰 ── -->
			<div class="about-section">
				<h2>Technical Foundation</h2>
				<p class="tech-intro">
					역할 기반 멀티에이전트 시스템으로 운영됩니다.
				</p>
				<div class="tech-groups">
					<div class="tech-group">
						<div class="tech-group-title">Orchestration</div>
						<ul>
							<li>OpenClaw v2026.3 <span class="tech-role">· framework</span></li>
							<li>Multi-agent pipeline <span class="tech-role">· 3 local + 1 API</span></li>
							<li>4-stage quality gates <span class="tech-role">· pass / fail / abort</span></li>
						</ul>
					</div>
					<div class="tech-group">
						<div class="tech-group-title">Models</div>
						<ul>
							<li>Qwen 3.6 35B-A3B MoE <span class="tech-role">· researcher</span></li>
							<li>DeepSeek V3.2 685B MoE <span class="tech-role">· writer (NVIDIA NIM API)</span></li>
							<li>Gemma 4 26B MoE <span class="tech-role">· reviewer</span></li>
							<li>Nemotron-3-Super 120B <span class="tech-role">· orchestrator (NVIDIA NIM API)</span></li>
						</ul>
					</div>
					<div class="tech-group">
						<div class="tech-group-title">Validation</div>
						<ul>
							<li>Claim labeling <span class="tech-role">· supported / inference / speculation</span></li>
							<li>5-axis review <span class="tech-role">· factual / citation / novelty / assumption / readability</span></li>
							<li>Cross-model verification <span class="tech-role">· 3 model families</span></li>
						</ul>
					</div>
					<div class="tech-group">
						<div class="tech-group-title">Research Sources</div>
						<ul>
							<li>arXiv API <span class="tech-role">· preprints</span></li>
							<li>OpenAlex <span class="tech-role">· 200M+ works</span></li>
							<li>CrossRef <span class="tech-role">· DOI metadata</span></li>
							<li>Semantic Scholar <span class="tech-role">· fallback</span></li>
						</ul>
					</div>
					<div class="tech-group">
						<div class="tech-group-title">Infrastructure</div>
						<ul>
							<li>Astro <span class="tech-role">· static site</span></li>
							<li>GitHub Actions <span class="tech-role">· CI/CD</span></li>
							<li>Supabase <span class="tech-role">· analytics</span></li>
						</ul>
					</div>
					<div class="tech-group">
						<div class="tech-group-title">Hardware</div>
						<ul>
							<li>RTX 5070 8GB <span class="tech-role">· local inference</span></li>
							<li>64GB RAM <span class="tech-role">· MoE offload</span></li>
						</ul>
					</div>
				</div>
			</div>

			<!-- ── Human Role ── -->
			<div class="about-section">
				<h2>Human Role</h2>
				<p class="purpose-lead">
					이곳의 글은 AI가 먼저 만들고 최종 판단은 제가 합니다.
				</p>
				<p class="purpose-body">
					논문을 찾고 근거를 정리하고 초안을 만드는 일까지는 AI가 맡을 수 있습니다. 하지만 어떤 질문을 던질지 어떤 방향으로 엮을지 이 글이 정말 공개할 만한 수준인지 판단하는 일은 여전히 인간의 몫이라고 생각합니다.
				</p>
				<p class="purpose-body">
