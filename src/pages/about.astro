---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE } from '../consts';

const articles = await getCollection('articles');
const articleCount = articles.length;
const catCount = new Set(articles.map(a => a.data.category)).size;
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`About | ${SITE_TITLE}`} description="AI를 쓰는 과정에서 사람의 판단이 어떻게 달라지는지 기록한다. 결과물이 아니라 판단의 기록." />
		<style>
			.about-header,
			.about-section,
			.closing {
				word-break: keep-all;
				line-break: strict;
				overflow-wrap: break-word;
			}

			/* ── Header ── */
			.about-header {
				padding: 5em 0 3em;
			}
			.about-header .label {
				font-family: var(--font-mono);
				font-size: 0.68em;
				color: var(--text-muted);
				text-transform: uppercase;
				letter-spacing: 0.08em;
				margin-bottom: 1.5em;
				display: block;
			}
			.about-header h1 {
				font-size: 2.8em;
				font-weight: 300;
				letter-spacing: -0.02em;
				margin-bottom: 0.4em;
			}
			.about-header .tagline {
				font-family: var(--font-serif);
				font-size: 1.15em;
				color: var(--text-secondary);
				font-style: italic;
				line-height: 1.7;
				margin-bottom: 1.5em;
			}
			.about-header .manifesto {
				font-size: 0.88em;
				color: var(--text-secondary);
				line-height: 1.9;
				max-width: 540px;
				margin-bottom: 0.8em;
			}

			/* ── About hero image ── */
			.about-hero-img {
				position: relative;
				width: 100%;
				height: 190px;
				overflow: hidden;
				border-radius: 4px;
				border: 1px solid var(--border);
				margin: 2em 0;
				background: #0b0b0e;
			}
			.about-hero-img img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				object-position: center center;
				display: block;
				opacity: 0.88;
				user-select: none;
				pointer-events: none;
			}
			/* Top+bottom inner fade */
			.about-hero-img::after {
				content: '';
				position: absolute;
				inset: 0;
				background: linear-gradient(
					to bottom,
					rgba(11,11,14,0.35) 0%,
					rgba(11,11,14,0) 30%,
					rgba(11,11,14,0) 70%,
					rgba(11,11,14,0.35) 100%
				);
				pointer-events: none;
			}
			@media (max-width: 720px) {
				.about-hero-img { height: 130px; }
			}

			/* Stats bar */
			.about-stats {
				display: flex;
				flex-wrap: wrap;
				gap: 0;
				margin-top: 2.5em;
				padding-top: 1.6em;
				border-top: 1px solid var(--border);
			}
			.stat-item {
				display: flex;
				flex-direction: column;
				gap: 0.2em;
				padding-right: 2.5em;
				border-right: 1px solid var(--border);
				margin-right: 2.5em;
			}
			.stat-item:last-child {
				border-right: none;
				padding-right: 0;
				margin-right: 0;
			}
			.stat-num {
				font-family: var(--font-mono);
				font-size: 1.6em;
				font-weight: 500;
				color: var(--accent);
				line-height: 1;
				letter-spacing: -0.02em;
			}
			.stat-label {
				font-family: var(--font-mono);
				font-size: 0.62em;
				color: var(--text-muted);
				text-transform: uppercase;
				letter-spacing: 0.06em;
				white-space: nowrap;
			}

			/* ── Sections ── */
			.about-section {
				padding: 3em 0;
				border-top: 1px solid var(--border);
			}
			.about-section h2 {
				font-family: var(--font-mono);
				font-size: 0.72em;
				font-weight: 400;
				color: var(--text-muted);
				letter-spacing: 0.08em;
				text-transform: uppercase;
				margin-bottom: 1.5em;
			}
			.purpose-lead {
				font-family: var(--font-serif);
				font-size: 1.05em;
				color: var(--text-primary);
				line-height: 1.8;
				max-width: 560px;
				margin-bottom: 1em;
			}
			.purpose-body {
				font-size: 0.88em;
				color: var(--text-secondary);
				line-height: 1.9;
				max-width: 560px;
				margin-bottom: 0.6em;
			}

			/* ── Fields of Inquiry ── */
			.field-intro {
				font-size: 0.85em;
				color: var(--text-muted);
				line-height: 1.7;
				max-width: 520px;
				margin-bottom: 2em;
			}
			.domain-grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 0;
			}
			.domain-card {
				position: relative;
				padding: 1.8em 1.8em 1.8em 0;
				border-bottom: 1px solid var(--border);
				transition: background 0.25s ease;
			}
			.domain-card:hover {
				background: rgba(255,255,255,0.015);
			}
			/* Colored left accent bar on each card */
			.domain-card::before {
				content: '';
				position: absolute;
				left: 0;
				top: 1.8em;
				bottom: 1.8em;
				width: 2px;
				background: var(--dc-color, var(--accent));
				border-radius: 1px;
				opacity: 0;
				transition: opacity 0.25s ease;
			}
			.domain-card:hover::before {
				opacity: 1;
			}
			.domain-card:nth-child(even) {
				padding-left: 1.8em;
				border-left: 1px solid var(--border);
			}
			.domain-card:nth-child(even)::before {
				left: 1.8em;
			}
			.domain-card:nth-child(-n+2) {
				border-top: 1px solid var(--border);
			}

			/* Colored top stripe per card */
			.domain-stripe {
				display: block;
				width: 28px;
				height: 3px;
				border-radius: 2px;
				background: var(--dc-color, var(--accent));
				margin-bottom: 1em;
			}
			.domain-name {
				font-family: var(--font-serif);
				font-weight: 600;
				font-size: 1.1em;
				color: var(--text-primary);
				display: block;
				margin-bottom: 0.5em;
			}
			.domain-question {
				font-family: var(--font-serif);
				font-size: 0.82em;
				color: var(--text-secondary);
				font-style: italic;
				line-height: 1.6;
				margin-bottom: 0.7em;
			}
			.domain-keywords {
				font-family: var(--font-mono);
				font-size: 0.65em;
				color: var(--text-muted);
				letter-spacing: 0.02em;
				line-height: 1.6;
			}

			/* ── Production System ── */
			.process-intro {
				font-size: 0.88em;
				color: var(--text-secondary);
				line-height: 1.9;
				max-width: 560px;
				margin-bottom: 2.5em;
			}
			.pipeline-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 0;
			}
			.pipeline-card {
				position: relative;
				padding: 1.6em 1.4em;
				border: 1px solid var(--border);
				border-right: none;
				border-bottom: none;
				overflow: hidden;
				transition: background 0.2s ease;
			}
			.pipeline-card:hover {
				background: rgba(184,160,122,0.03);
			}
			.pipeline-card:nth-child(3n) {
				border-right: 1px solid var(--border);
			}
			.pipeline-card:nth-child(-n+3) {
				border-top: 1px solid var(--border);
			}
			.pipeline-card:nth-child(n+4) {
				border-bottom: 1px solid var(--border);
			}

			/* Large atmospheric step number */
			.pipe-num {
				position: absolute;
				top: 0.3em;
				right: 0.4em;
				font-family: var(--font-mono);
				font-size: 3.2em;
				font-weight: 700;
				color: rgba(184,160,122,0.07);
				line-height: 1;
				letter-spacing: -0.04em;
				pointer-events: none;
				user-select: none;
			}
			.pipe-step {
				font-family: var(--font-mono);
				font-size: 0.58em;
				color: var(--accent);
				letter-spacing: 0.06em;
				text-transform: uppercase;
				display: block;
				margin-bottom: 0.5em;
				opacity: 0.8;
			}
			.pipe-label {
				font-family: var(--font-mono);
				font-size: 0.82em;
				color: var(--text-primary);
				letter-spacing: 0.01em;
				font-weight: 500;
				display: block;
				margin-bottom: 0.5em;
			}
			.pipe-desc {
				font-size: 0.78em;
				color: var(--text-secondary);
				line-height: 1.65;
			}
			.pipe-agent {
				font-family: var(--font-mono);
				font-size: 0.6em;
				color: var(--text-muted);
				letter-spacing: 0.01em;
				display: block;
				margin-top: 0.8em;
				padding-top: 0.7em;
				border-top: 1px solid rgba(255,255,255,0.04);
			}
			.process-note {
				margin-top: 2em;
				font-size: 0.82em;
				color: var(--text-muted);
				line-height: 1.7;
				max-width: 540px;
			}

			/* ── Tech Stack ── */
			.tech-intro {
				font-size: 0.85em;
				color: var(--text-muted);
				line-height: 1.7;
				max-width: 520px;
				margin-bottom: 2em;
			}
			.tech-groups {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 0;
			}
			.tech-group {
				padding: 1.5em 1.5em 1.5em 0;
				border-bottom: 1px solid var(--border);
			}
			.tech-group:nth-child(even) {
				padding-left: 1.5em;
				border-left: 1px solid var(--border);
			}
			.tech-group:nth-child(-n+2) {
				border-top: 1px solid var(--border);
			}
			.tech-group-title {
				font-family: var(--font-mono);
				font-size: 0.66em;
				color: var(--accent);
				letter-spacing: 0.06em;
				text-transform: uppercase;
				margin-bottom: 0.8em;
			}
			.tech-group ul {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.tech-group li {
				font-size: 0.82em;
				color: var(--text-secondary);
				line-height: 1.5;
				padding: 0.2em 0;
			}
			.tech-role {
				font-family: var(--font-mono);
				font-size: 0.9em;
				color: var(--text-muted);
			}

			/* ── Human Role + CTA ── */
			.about-cta {
				margin-top: 2.5em;
				display: flex;
				align-items: center;
				gap: 1.2em;
				flex-wrap: wrap;
			}
			.btn-articles {
				display: inline-flex;
				align-items: center;
				gap: 0.5em;
				padding: 0.7em 1.4em;
				border: 1px solid var(--accent);
				color: var(--accent);
				font-family: var(--font-mono);
				font-size: 0.75em;
				letter-spacing: 0.04em;
				text-decoration: none;
				border-radius: 3px;
				transition: background 0.2s ease, color 0.2s ease;
			}
			.btn-articles:hover {
				background: var(--accent);
				color: var(--bg-primary);
			}
			.btn-ghost {
				display: inline-flex;
				align-items: center;
				gap: 0.4em;
				color: var(--text-muted);
				font-family: var(--font-mono);
				font-size: 0.72em;
				letter-spacing: 0.04em;
				text-decoration: none;
				transition: color 0.2s ease;
			}
			.btn-ghost:hover { color: var(--accent); }

			/* ── Big question + chips ── */
			.big-question {
				font-family: var(--font-serif);
				font-size: 1.9em;
				font-weight: 300;
				line-height: 1.5;
				color: var(--text-primary);
				letter-spacing: -0.01em;
				margin-bottom: 1.2em;
			}
			.big-question em {
				font-style: normal;
				color: var(--accent);
				border-bottom: 1px solid var(--accent);
			}
			.q-chips {
				display: flex;
				flex-wrap: wrap;
				gap: 0.6em;
			}
			.q-chip {
				font-family: var(--font-mono);
				font-size: 0.7em;
				color: var(--text-secondary);
				border: 1px solid var(--border);
				border-radius: 999px;
				padding: 0.45em 1em;
				letter-spacing: 0.02em;
			}

			/* ── Gate badge ── */
			.gate-badge {
				display: inline-block;
				font-family: var(--font-mono);
				font-size: 0.78em;
				color: var(--accent);
				border: 1px solid rgba(184,160,122,0.4);
				border-radius: 3px;
				padding: 0.25em 0.7em;
				margin-left: 0.6em;
				letter-spacing: 0.03em;
				white-space: nowrap;
			}

			/* ── Role separation strip ── */
			.role-strip {
				display: flex;
				align-items: center;
				gap: 1em;
				margin: 2em 0 1.2em;
				flex-wrap: wrap;
			}
			.role-cell {
				display: flex;
				flex-direction: column;
				gap: 0.25em;
				border: 1px solid var(--border);
				border-radius: 4px;
				padding: 0.9em 1.5em;
				text-align: center;
			}
			.role-name {
				font-family: var(--font-serif);
				font-size: 0.95em;
				color: var(--text-primary);
			}
			.role-model {
				font-family: var(--font-mono);
				font-size: 0.62em;
				color: var(--text-muted);
				text-transform: uppercase;
				letter-spacing: 0.08em;
			}
			.role-x {
				font-family: var(--font-mono);
				font-size: 1.3em;
				color: var(--accent);
				opacity: 0.85;
			}

			/* ── Human/AI split ── */
			.hr-split {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 0;
				border: 1px solid var(--border);
				border-radius: 4px;
				overflow: hidden;
				max-width: 560px;
			}
			.hr-col {
				padding: 1.5em 1.6em;
			}
			.hr-col.human {
				border-left: 1px solid var(--border);
				background: rgba(184,160,122,0.04);
			}
			.hr-head {
				font-family: var(--font-mono);
				font-size: 0.66em;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--text-muted);
				margin-bottom: 0.9em;
			}
			.hr-col.human .hr-head {
				color: var(--accent);
			}
			.hr-col ul {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.hr-col li {
				font-family: var(--font-serif);
				font-size: 0.88em;
				color: var(--text-secondary);
				line-height: 1.6;
				padding: 0.22em 0;
			}
			.hr-col.human li {
				color: var(--text-primary);
			}
			.hr-split + .purpose-body {
				margin-top: 1.4em;
			}

			/* ── Hero reversal (2-beat) ── */
			.rev-line {
				font-family: var(--font-serif);
				line-height: 1.6;
				margin: 0;
			}
			.rev-line.dim {
				font-size: 1.05em;
				color: var(--text-muted);
				margin-bottom: 0.3em;
			}
			.rev-line.hit {
				font-size: 1.35em;
				color: var(--text-primary);
				border-left: 2px solid var(--accent);
				padding-left: 0.6em;
				margin-bottom: 1.6em;
			}

			/* ── Question closing line ── */
			.q-closing {
				font-size: 0.85em;
				color: var(--text-muted);
				margin-top: 1.4em;
				line-height: 1.7;
			}

			/* ── Claim taxonomy chips ── */
			.claim-strip {
				display: flex;
				gap: 0.6em;
				margin: 1.8em 0 1em;
				flex-wrap: wrap;
			}
			.claim-chip {
				font-family: var(--font-mono);
				font-size: 0.62em;
				letter-spacing: 0.08em;
				padding: 0.45em 0.9em;
				border-radius: 3px;
				border: 1px solid var(--border);
			}
			.claim-chip.c-sup  { color: var(--cat-agent, #7ab8b0); border-color: rgba(122,184,176,0.45); }
			.claim-chip.c-inf  { color: var(--accent); border-color: rgba(184,160,122,0.45); }
			.claim-chip.c-spec { color: var(--cat-cognition, #9088b8); border-color: rgba(144,136,184,0.45); }

			/* ── Scroll reveal ── */
			.reveal {
				opacity: 0;
				transform: translateY(18px);
				transition: opacity 0.55s ease, transform 0.55s ease;
			}
			.reveal.visible {
				opacity: 1;
				transform: none;
			}

			/* ── Responsive ── */
			@media (max-width: 720px) {
				.about-header { padding: 3.5em 0 2em; }
				.about-header h1 { font-size: 2em; }
				.about-stats { gap: 0; }
				.stat-item { padding-right: 1.6em; margin-right: 1.6em; }
				.stat-num { font-size: 1.3em; }

				.domain-grid { grid-template-columns: 1fr; }
				.domain-card { padding: 1.4em 0; }
				.domain-card:nth-child(even) { padding-left: 0; border-left: none; }
				.domain-card:nth-child(-n+2) { border-top: none; }
				.domain-card:first-child { border-top: 1px solid var(--border); }

				.pipeline-grid { grid-template-columns: 1fr; }
				.pipeline-card {
					border-right: 1px solid var(--border);
					border-bottom: none;
				}
				.pipeline-card:last-child { border-bottom: 1px solid var(--border); }
				.pipeline-card:nth-child(3n) { border-right: 1px solid var(--border); }
				.pipe-num { font-size: 2.4em; }

				.tech-groups { grid-template-columns: 1fr; }
				.tech-group { padding: 1.2em 0; }
				.tech-group:nth-child(even) { padding-left: 0; border-left: none; }
				.tech-group:nth-child(-n+2) { border-top: none; }
				.tech-group:first-child { border-top: 1px solid var(--border); }

				.big-question { font-size: 1.45em; }
				.rev-line.hit { font-size: 1.15em; }
				.gate-badge { margin-left: 0; margin-top: 0.6em; display: inline-block; }
				.role-strip { gap: 0.6em; }
				.role-cell { padding: 0.7em 1em; flex: 1; }
				.hr-split { grid-template-columns: 1fr; }
				.hr-col.human { border-left: none; border-top: 1px solid var(--border); }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<!-- ── 1. Identity ── -->
			<div class="about-header">
				<span class="label">About</span>
				<h1>Ji Research Library</h1>
				<p class="rev-line dim">AI를 쓰면 글을 더 빨리 쓸 수 있다.</p>
				<p class="rev-line hit">하지만 내가 보고 싶은 건 속도가 아니다.</p>

				<!-- AI–Human neural connection visual -->
				<div class="about-hero-img">
					<img src="/profji-library/images/about-hero.png" alt="AI와 인간 인지의 연결" width="1440" height="300" loading="eager" decoding="async" />
				</div>

				<p class="manifesto">
					AI를 쓰는 과정에서 사람의 판단이 어떻게 달라지는지 보고 싶었다.
					어디서 더 명확해지고 어디서 더 쉽게 기대게 되는지.
					전문성은 약해지는지, 아니면 다른 형태로 바뀌는지.
					Ji Research Library는 그 과정을 기록하는 곳이다.
				</p>
				<p class="manifesto">
					여기 올라오는 글은 단순한 결과물이 아니다.
					AI와 함께 만들고 다시 검증하고 사람이 마지막으로 판단한 기록이다.
					완성된 글만 보여주기보다 그 글이 어떻게 만들어졌는지도 함께 남긴다.
				</p>

				<!-- Stats bar -->
				<div class="about-stats">
					<div class="stat-item">
						<span class="stat-num">{articleCount}</span>
						<span class="stat-label">Essays published</span>
					</div>
					<div class="stat-item">
						<span class="stat-num">{catCount}</span>
						<span class="stat-label">Research axes</span>
					</div>
					<div class="stat-item">
