---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

const { title, description, pubDate, updatedDate, category, tags } = Astro.props;
---

<html lang="ko">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			.article-header {
				max-width: 640px;
				margin: 0 auto;
				padding: 4em 1em 1.5em;
			}
			.article-header .cat-row {
				display: flex;
				align-items: center;
				gap: 0.6em;
				margin-bottom: 1.5em;
			}
			.article-header .cat-dot {
				width: 7px;
				height: 7px;
				border-radius: 50%;
				background: var(--accent);
			}
			.article-header .cat-name {
				font-family: var(--font-mono);
				font-size: 0.68em;
				color: var(--text-muted);
				text-transform: uppercase;
				letter-spacing: 0.06em;
			}
			.article-header h1 {
				font-size: 2.2em;
				font-weight: 400;
				line-height: 1.35;
				margin-bottom: 0.6em;
			}
			.article-header .meta {
				font-family: var(--font-mono);
				font-size: 0.7em;
				color: var(--text-muted);
				letter-spacing: 0.03em;
			}
			.article-header .tags {
				margin-top: 1.2em;
				display: flex;
				gap: 0.5em;
				flex-wrap: wrap;
			}
			.article-header .tag {
				font-family: var(--font-mono);
				font-size: 0.68em;
				color: var(--text-muted);
				padding: 0.25em 0.6em;
				border: 1px solid var(--border);
				border-radius: 3px;
				letter-spacing: 0.02em;
			}

			/* ── Prose ── */
			.prose {
				width: 640px;
				max-width: calc(100% - 2em);
				margin: 2.5em auto;
				padding: 0 1em;
				color: var(--text-secondary);
			}
			.prose :global(h2) {
				font-family: var(--font-serif);
				font-size: 1.5em;
				font-weight: 400;
				margin-top: 3em;
				padding-bottom: 0.4em;
				border-bottom: 1px solid var(--border);
				color: var(--text-primary);
			}
			.prose :global(h3) {
				font-family: var(--font-serif);
				font-size: 1.2em;
				font-weight: 600;
				margin-top: 2.5em;
				color: var(--text-primary);
			}
			.prose :global(strong) {
				color: var(--text-primary);
				font-weight: 600;
			}
			.prose :global(a) {
				color: var(--accent);
				text-decoration: underline;
				text-underline-offset: 3px;
				text-decoration-color: rgba(184, 160, 122, 0.3);
			}
			.prose :global(a:hover) {
				text-decoration-color: var(--accent);
			}
			.prose :global(blockquote) {
				border-left: 2px solid var(--accent);
				padding-left: 1.5em;
				margin: 2em 0;
				font-family: var(--font-serif);
				font-style: italic;
				color: var(--text-secondary);
			}
			.prose :global(ul), .prose :global(ol) {
				padding-left: 1.5em;
			}
			.prose :global(li) {
				margin-bottom: 0.5em;
				line-height: 1.8;
			}

			@media (max-width: 720px) {
				.article-header h1 { font-size: 1.7em; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<article>
				<div class="article-header">
					{category && (
						<div class="cat-row">
							<span class="cat-dot"></span>
							<span class="cat-name">{category}</span>
						</div>
					)}
					<h1>{title}</h1>
					<div class="meta"><FormattedDate date={pubDate} /></div>
					{tags && tags.length > 0 && (
						<div class="tags">
							{tags.map((tag: string) => <span class="tag">#{tag}</span>)}
						</div>
					)}
				</div>
				<hr />
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
