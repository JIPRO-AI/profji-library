---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import ViewCounter from '../components/ViewCounter.astro';

const { title, description, pubDate, updatedDate, category, tags, slug, ogImage } = Astro.props;
---

<html lang="ko">
	<head>
		<BaseHead title={title} description={description} image={ogImage} />
		<style>
			.article-header {
				max-width: 660px;
				margin: 0 auto;
				padding: 4em 1em 1.5em;
			}
			.article-header .cat-row {
				display: flex;
				align-items: center;
				gap: 0.6em;
				margin-bottom: 1.5em;
			}
			.article-header .cat-dot {
				width: 7px;
				height: 7px;
				border-radius: 50%;
				background: var(--accent);
			}
			.article-header .cat-name {
				font-family: var(--font-mono);
				font-size: 0.68em;
				color: var(--text-muted);
				text-transform: uppercase;
				letter-spacing: 0.06em;
			}
			.article-header h1 {
				font-size: 2.2em;
				font-weight: 400;
				line-height: 1.35;
				margin-bottom: 0.6em;
			}
			.article-header .meta {
				font-family: var(--font-mono);
				font-size: 0.7em;
				color: var(--text-muted);
				letter-spacing: 0.03em;
			}
			.article-header .tags {
				margin-top: 1.2em;
				display: flex;
				gap: 0.5em;
				flex-wrap: wrap;
			}
			.article-header .tag {
				font-family: var(--font-mono);
				font-size: 0.68em;
				color: var(--text-muted);
				padding: 0.25em 0.6em;
				border: 1px solid var(--border);
				border-radius: 3px;
				letter-spacing: 0.02em;
			}

			/* ── Prose ── */
			.prose {
				width: 660px;
				max-width: calc(100% - 2em);
				margin: 2.5em auto;
				padding: 0 1em;
				color: var(--text-secondary);
			}
			.prose :global(h2) {
				font-family: var(--font-serif);
				font-size: 1.5em;
				font-weight: 400;
				margin-top: 3em;
				padding-bottom: 0.4em;
				border-bottom: 1px solid var(--border);
				color: var(--text-primary);
			}
			.prose :global(h3) {
				font-family: var(--font-serif);
				font-size: 1.2em;
				font-weight: 600;
				margin-top: 2.5em;
				color: var(--text-primary);
			}
			.prose :global(strong) {
				color: var(--text-primary);
				font-weight: 600;
			}
			.prose :global(a) {
				color: var(--accent);
				text-decoration: underline;
				text-underline-offset: 3px;
				text-decoration-color: rgba(184, 160, 122, 0.3);
				transition: text-decoration-color 0.3s ease;
			}
			.prose :global(a:hover) {
				text-decoration-color: var(--accent);
			}
			/* ── Pull-quote blockquotes ── */
			.prose :global(blockquote) {
				position: relative;
				border-left: 2px solid var(--accent);
				padding: 0.5em 0 0.5em 2em;
				margin: 2.5em 0 2.5em -0.5em;
				font-family: var(--font-serif);
				font-style: italic;
				font-size: 1.08em;
				line-height: 1.8;
				color: var(--text-secondary);
			}
			.prose :global(blockquote::before) {
				content: "\201C";
				position: absolute;
				left: 0.35em;
				top: -0.1em;
				font-family: var(--font-serif);
				font-size: 3em;
				color: rgba(184, 160, 122, 0.15);
				line-height: 1;
				pointer-events: none;
			}
			.prose :global(blockquote p) {
				margin-bottom: 0.6em;
			}
			.prose :global(ul), .prose :global(ol) {
				padding-left: 1.5em;
			}
			.prose :global(li) {
				margin-bottom: 0.5em;
				line-height: 1.8;
			}

			/* ── Responsive Tables ── */
			.prose :global(table) {
				width: 100%;
				display: block;
				overflow-x: auto;
				-webkit-overflow-scrolling: touch;
				margin: 2em 0;
				border: 1px solid var(--border);
				border-radius: 6px;
			}
			.prose :global(thead),
			.prose :global(tbody) {
				display: table;
				width: 100%;
			}
			.prose :global(tr) {
				display: table-row;
			}
			.prose :global(th) {
				background: rgba(184, 160, 122, 0.06);
				font-size: 0.7em;
				padding: 0.8em 1em;
				border-bottom: 1px solid var(--border);
			}
			.prose :global(td) {
				padding: 0.7em 1em;
				font-size: 0.92em;
				line-height: 1.6;
				vertical-align: top;
				border-bottom: 1px solid rgba(39, 39, 44, 0.6);
			}
			.prose :global(tr:last-child td) {
				border-bottom: none;
			}
			.prose :global(tbody tr:hover) {
				background: rgba(184, 160, 122, 0.04);
			}

			/* ── Mobile: Table → Card Layout ── */
			@media (max-width: 720px) {
				.article-header h1 { font-size: 1.7em; }
				.prose :global(blockquote) { margin-left: 0; }

				.prose :global(table) {
					border: none;
					border-radius: 0;
				}
				.prose :global(thead) {
					display: none;
				}
				.prose :global(tbody) {
					display: block;
				}
				.prose :global(tr) {
					display: block;
					border: 1px solid var(--border);
					border-radius: 6px;
					margin-bottom: 1em;
					padding: 0.8em 1em;
					background: rgba(184, 160, 122, 0.03);
				}
				.prose :global(td) {
					display: block;
					padding: 0.3em 0;
					border-bottom: none;
					font-size: 0.88em;
				}
				.prose :global(td::before) {
					content: attr(data-label);
					display: block;
					font-family: var(--font-mono);
					font-size: 0.72em;
					color: var(--text-muted);
					text-transform: uppercase;
					letter-spacing: 0.08em;
					margin-bottom: 0.15em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<article>
				<div class="article-header">
					{category && (
						<div class="cat-row">
							<span class="cat-dot"></span>
							<span class="cat-name">{category}</span>
						</div>
					)}
					<h1>{title}</h1>
					<div class="meta">
						<FormattedDate date={pubDate} />
						{slug && <span style="margin-left: 1.5em;"><ViewCounter slug={slug} increment={true} /></span>}
					</div>
					{tags && tags.length > 0 && (
						<div class="tags">
							{tags.map((tag: string) => <span class="tag">#{tag}</span>)}
						</div>
					)}
				</div>
				<hr />
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
		<script>
			// Inject data-label attributes for mobile card layout
			document.querySelectorAll('.prose table').forEach(table => {
				const headers = Array.from(table.querySelectorAll('thead th')).map(th => th.textContent.trim());
				if (headers.length === 0) return;
				table.querySelectorAll('tbody tr').forEach(tr => {
					tr.querySelectorAll('td').forEach((td, i) => {
						if (headers[i]) td.setAttribute('data-label', headers[i]);
					});
				});
			});
		</script>
	</body>
</html>
