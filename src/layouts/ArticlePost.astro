---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

const { title, description, pubDate, updatedDate, category, tags } = Astro.props;
---

<html lang="ko">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			.article-header {
				max-width: 720px;
				margin: 0 auto;
				padding: 3em 1em 1em;
				text-align: center;
			}
			.article-header .cat-badge {
				display: inline-block;
				padding: 0.3em 0.8em;
				background: var(--accent-dim);
				color: var(--accent);
				border-radius: 100px;
				font-size: 0.75em;
				font-weight: 600;
				margin-bottom: 1em;
			}
			.article-header h1 {
				font-size: 2em;
				line-height: 1.3;
				margin-bottom: 0.5em;
			}
			.article-header .meta {
				color: var(--text-muted);
				font-size: 0.85em;
			}
			.article-header .tags {
				margin-top: 1em;
				display: flex;
				gap: 0.4em;
				justify-content: center;
				flex-wrap: wrap;
			}
			.article-header .tag {
				padding: 0.2em 0.6em;
				background: var(--bg-card);
				border: 1px solid var(--border);
				border-radius: 4px;
				font-size: 0.75em;
				color: var(--text-muted);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: 2em auto;
				padding: 0 1em;
				color: var(--text-secondary);
			}
			.prose :global(h2) {
				margin-top: 2.5em;
				padding-bottom: 0.3em;
				border-bottom: 1px solid var(--border);
			}
			.prose :global(h3) {
				margin-top: 2em;
			}
			.prose :global(strong) {
				color: var(--text-primary);
			}
			.prose :global(a) {
				color: var(--accent);
				text-decoration: underline;
				text-underline-offset: 2px;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<article>
				<div class="article-header">
					{category && <span class="cat-badge">{category}</span>}
					<div class="meta"><FormattedDate date={pubDate} /></div>
					<h1>{title}</h1>
					{tags && tags.length > 0 && (
						<div class="tags">
							{tags.map((tag: string) => <span class="tag">#{tag}</span>)}
						</div>
					)}
				</div>
				<hr />
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
